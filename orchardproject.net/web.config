<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="Redirect to orchardcore.net">
          <match url="^(.*)$" />
          <action type="Redirect" url="https://orchardcore.net" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
