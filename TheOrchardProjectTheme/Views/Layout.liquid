<!DOCTYPE html>
<html lang="{{ Culture.Name }}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    {% render_section "HeadMeta", required: false %}
    <title>{% page_title Site.SiteName %}</title>
    {% resources type: "Meta" %}

    <!-- Bootstrap core CSS -->
    {% style name:"vendor-bootstrap", version:"4" %}

    <!-- Custom fonts for this template -->
    {% style name:"vendor-font-awesome", version:"5" %}
    <link href="https://fonts.googleapis.com/css?family=Montserrat:400,700" rel="stylesheet" type="text/css">
    <link href='https://fonts.googleapis.com/css?family=Kaushan+Script' rel='stylesheet' type='text/css'>
    <link href='https://fonts.googleapis.com/css?family=Droid+Serif:400,700,400italic,700italic' rel='stylesheet' type='text/css'>
    <link href='https://fonts.googleapis.com/css?family=Roboto+Slab:400,100,300,700' rel='stylesheet' type='text/css'>
    <link rel="icon" type="image/png" href="/favicon.png" sizes="32x32">  

    <!-- Custom styles for this template -->
    {% style src:"~/TOPT/css/agency.min.css", debug_src:"~/TOPT/css/agency.css" %}
    {% style src:"~/TOPT/bootstrap-grid-ext.min.css", debug_src:"~/TOPT/bootstrap-grid-ext.css" %}

    <!-- Bootstrap core JavaScript -->
    {% script name:"vendor-jquery", at:"Foot" %}    
    {% script name:"vendor-bootstrap-bundle", at:"Foot" %}

    <!-- Plugin JavaScript -->
    {% script name:"vendor-jquery.easing", at:"Foot" %}    
    
    <!-- Contact form JavaScript -->

    <!-- Custom scripts for this template -->
    {% script src:"~/TOPT/js/agency.min.js", debug_src:"~/TOPT/js/agency.min.js", at:"Foot" %}

    {% resources type: "HeadScript" %}
    {% resources type: "HeadLink" %}
    {% resources type: "Stylesheet" %}

</head>
<body id="page-top" dir="{{ Culture.Dir }}">
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand js-scroll-trigger" href="{{ '~/#page-top' | href }}">
                <img src="/TOPT/img/vignette.png" />{{ Site.SiteName }}</a>
            <button class="navbar-toggler navbar-toggler-right" type="button" data-toggle="collapse" data-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
                Menu 
                <i class="fas fa-bars"></i>
            </button>
            {% shape "menu", alias: "alias:main-menu", cache_id: "main-menu", cache_tag: "alias:main-menu" %}
        </div>
    </nav>
    {% render_section "Header", required: false %}
    <div class="container" id="main">
        {% render_section "Content" %}
    </div>
	<footer class="footer">
		<div class="container">
			<div class="row">
				<div class="col-md-4">
				</div>
				<div class="col-md-4">
					<ul class="list-inline social-buttons">
						<li class="list-inline-item">
							<a href="https://twitter.com/orchardcms">
								<i class="fab fa-twitter"></i>
							</a>
						</li>
						<li class="list-inline-item">
							<a href="https://www.facebook.com/orchardcore/">
								<i class="fab fa-facebook-f"></i>
							</a>
						</li>
						<li class="list-inline-item">
							<a href="https://www.youtube.com/channel/UCcEaR8HfGpPwt-GqJr_h5UQ">
								<i class="fab fa-youtube"></i>
							</a>
						</li>
					</ul>
				</div>
				<div class="col-md-4">
					<span class="copyright">Copyright &copy; .NET Foundation</span>
				</div>
			</div>
		</div>
	</footer>
    {% render_section "Footer", required: false %}
    {% resources type: "FootScript" %}
</body>
</html>
