		<PackageReference Include="OrchardCore.Theme.Targets" Version="3.0.0" />
		<PackageReference Include="OrchardCore.Flows" Version="3.0.0" />
		<PackageReference Include="OrchardCore.Notifications" Version="3.0.0" />
		<PackageReference Include="OrchardCore.Themes" Version="3.0.0" />
		<PackageReference Include="OrchardCore.Admin.Abstractions" Version="3.0.0" />
		<PackageReference Include="OrchardCore.Users.Abstractions" Version="3.0.0" />
		<PackageReference Include="OrchardCore.Users" Version="3.0.0" />
		<PackageReference Include="OrchardCore.Menu" Version="3.0.0" />
	</ItemGroup>
	
</Project>
