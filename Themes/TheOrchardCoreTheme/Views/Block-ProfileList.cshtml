@using Microsoft.AspNetCore.Html
@*
    Profile List. A compact people grid: an optional heading + lead, then small circular avatars with a
    name, role, and GitHub/LinkedIn icons laid out horizontally — plus the shared BlockActions closing
    row. Band/anchor + theme come from the Block part. Reusable for organisers, contributors, etc.
*@
@{
    var item = (ContentItem)Model.ContentItem;
    var intro = item.Get<ContentPart>("BlockIntro");
    var section = item.Get<ContentPart>("BlockPart");
    var theme = section?.Get<TextField>("Theme")?.Text;
    var themeName = (string.IsNullOrEmpty(theme) ? "White" : theme).ToLowerInvariant();
    var anchor = section?.Get<TextField>("AnchorId")?.Text;
    var profiles = item.Get<BagPart>("Profiles")?.ContentItems ?? [];
    var blockActions = item.Get<ContentPart>("BlockActionsPart");

    // Closing actions row: copy from BlockActionsPart, buttons from the CallToActions bag.
    var actionsHtml = new HtmlContentBuilder();
    foreach (var cta in item.Get<BagPart>("CallToActions")?.ContentItems ?? [])
    {
        var callToAction = cta.Get<ContentPart>("CallToAction");
        var link = callToAction?.Get<LinkField>("Link");
        actionsHtml.AppendHtml(await DisplayAsync(await New.Button(Url: link?.Url, Text: link?.Text, Target: link?.Target, Variant: callToAction?.Get<TextField>("Variant")?.Text)));
    }
}
<section id="@(string.IsNullOrEmpty(anchor) ? null : anchor)" class="theme-@themeName">
    <div class="mx-auto max-w-content px-6 band">

        @await DisplayAsync(await New.BlockIntro(Title: intro?.Get<TextField>("Title")?.Text, Lead: intro?.Get<HtmlField>("Lead")?.Html))

        @if (profiles.Count > 0)
        {
            <ul class="mt-12 grid gap-x-8 gap-y-6 sm:grid-cols-2 lg:grid-cols-3">
                @* The whole row links to the person's GitHub profile (like the v1 design); the
                   subtitle is their GitHub handle, derived from the URL. Falls back to a non-linked row if no
                   GitHub URL is set. The Role/LinkedIn fields aren't used by this compact layout. *@
                @foreach (var profile in profiles)
                {
                    var github = profile.Get<ContentPart>("Profile")?.Get<TextField>("GitHubUrl")?.Text;
                    var hasGithub = !string.IsNullOrEmpty(github);
                    var handle = hasGithub ? github!.Split('/').Last() : "";
                    <li>
                        @{
                            var avatar = await DisplayAsync(await New.ProfileAvatar(Item: profile, Width: 140, Sizes: "70px", Class: "h-[70px] w-[70px] shrink-0 rounded-xl object-cover bg-cream theme-dark:bg-white/5"));
                        }
                        @if (hasGithub)
                        {
                            <a href="@Url.Content(github)" target="_blank" rel="noopener" class="group flex items-center gap-4">
                                @avatar
                                <span class="min-w-0">
                                    <span class="block truncate text-base text-green-900 theme-dark:text-white transition group-hover:text-green-700 theme-dark:group-hover:text-accent-bright">@profile.DisplayText</span>
                                    @if (!string.IsNullOrEmpty(handle))
                                    {
                                        <span class="block truncate text-sm text-ink-soft theme-dark:text-green-100/70">@("@" + handle)</span>
                                    }
                                </span>
                            </a>
                        }
                        else
                        {
                            <div class="flex items-center gap-4">
                                @avatar
                                <span class="min-w-0">
                                    <span class="block truncate text-base text-green-900 theme-dark:text-white transition group-hover:text-green-700 theme-dark:group-hover:text-accent-bright">@profile.DisplayText</span>
                                </span>
                            </div>
                        }
                    </li>
                }
            </ul>
        }

        @await DisplayAsync(await New.BlockActions(Heading: blockActions?.Get<TextField>("Heading")?.Text, Text: blockActions?.Get<HtmlField>("Text")?.Html, Actions: actionsHtml, MaxWidth: "max-w-none"))

    </div>
</section>
