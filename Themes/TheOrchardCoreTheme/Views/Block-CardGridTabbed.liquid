{%- comment -%}
  Cards Grid (Tabbed). An optional heading + lead, then audience tabs of cards (rendered by the shared
  CardTabs shape, which uses the shared Card shape), plus the shared BlockActions closing row.
  Band/anchor + theme come from the Block part.
{%- endcomment -%}
{%- assign intro = Model.ContentItem.Content.BlockIntro -%}
{%- assign section = Model.ContentItem.Content.BlockPart -%}
{%- assign themeName = section.Theme.Text | default: "White" | downcase -%}
{%- assign anchor = section.AnchorId.Text -%}
{%- assign tabs = Model.ContentItem.Content.Tabs.ContentItems -%}
{%- assign blockActions = Model.ContentItem.Content.BlockActionsPart -%}

<section {% if anchor and anchor != "" %}id="{{ anchor }}"{% endif %} class="theme-{{ themeName }}">
  <div class="mx-auto max-w-content px-6 band">

    {{ "BlockIntro" | shape_new: title: intro.Title.Text, lead: intro.Lead.Html, wrapperWidth: "mx-auto max-w-4xl", leadWidth: "max-w-2xl" | shape_render }}

    {%- comment -%} Space the tabs below this block's own heading; when there's no heading (e.g. merged
      under a Statistics block) the section/merge padding above already provides the gap. {%- endcomment -%}
    {%- if tabs.size > 0 -%}
      <div{% if intro.Title.Text and intro.Title.Text != "" %} class="mt-12"{% endif %}>{{ "CardTabs" | shape_new: tabs: tabs, uid: Model.ContentItem.ContentItemId | shape_render }}</div>
    {%- endif -%}

    {%- comment -%} Closing actions row: copy from BlockActionsPart, buttons from the CallToActions bag. {%- endcomment -%}
    {%- capture actionsHtml -%}
      {%- for callToAction in Model.ContentItem.Content.CallToActions.ContentItems -%}
        {{ "Button" | shape_new: url: callToAction.CallToAction.Link.Url, text: callToAction.CallToAction.Link.Text, target: callToAction.CallToAction.Link.Target, variant: callToAction.CallToAction.Variant.Text | shape_render }}
      {%- endfor -%}
    {%- endcapture -%}
    {{ "BlockActions" | shape_new: heading: blockActions.Heading.Text, text: blockActions.Text.Html, actions: actionsHtml | shape_render }}

  </div>
</section>
