@*
    Community avatar row. Rendered by the [contributor_avatars] shortcode (in the module's automation
    recipe), which reads the SiteStatistics singleton's TopContributors JSON (kept fresh from the
    GitHub API) and passes:
      Contributors — the list of { login, avatar_url, html_url }
      Overflow     — how many more contributors exist beyond the avatars shown (the "+N" badge)
    Drop [contributor_avatars] into a Card body to show it. `not-prose` keeps the card's prose styling
    off the avatars.
*@
@{
    // The [contributor_avatars] shortcode template passes the list through Liquid, which may hand us a
    // plain array rather than the dynamic JSON array — normalize to a list before counting/enumerating.
    var contributors = ((object?)Model.Contributors as System.Collections.IEnumerable)?.Cast<object>().ToList();
    var overflow = (int?)Model.Overflow ?? 0;
}
@if (contributors is { Count: > 0 })
{
    <div class="not-prose mt-4 flex items-center">
        @{ var first = true; }
        @foreach (var contributor in contributors)
        {
            // Elements arrive as raw JsonObjects (Liquid hands over the parsed JSON), so index by name.
            var node = contributor as System.Text.Json.Nodes.JsonNode;
            var htmlUrl = node?["html_url"]?.GetValue<string>();
            var avatarUrl = node?["avatar_url"]?.GetValue<string>();
            var login = node?["login"]?.GetValue<string>();
            var hasUrl = !string.IsNullOrEmpty(htmlUrl);
            <a href="@(hasUrl ? htmlUrl : null)" target="@(hasUrl ? "_blank" : null)" rel="@(hasUrl ? "noopener" : null)" title="@login" class="shrink-0@(first ? "" : " -ml-2")">
                <img src="@(avatarUrl)?size=40" srcset="@(avatarUrl)?size=40 1x, @(avatarUrl)?size=80 2x" alt="@login" width="40" height="40" loading="lazy" decoding="async" class="block h-10 w-10 rounded-full bg-green-100 object-cover ring-2 ring-cream theme-dark:ring-white/10">
            </a>
            first = false;
        }
        @if (overflow > 0)
        {
            <span class="-ml-2 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-green-700 text-xs font-semibold text-white ring-2 ring-cream theme-dark:ring-white/10">+@overflow</span>
        }
    </div>
}
