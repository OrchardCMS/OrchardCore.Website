{%- comment -%}
  Partner promo (Widget, rendered in the 'Footer Top' zone). A heading + intro + CTA on the left, a grid
  of partner logo cards on the right. Reuses the shared Button shape for the CTA. Sits in the footer's
  theme-dark band.
{%- endcomment -%}
{%- assign promo = Model.ContentItem.Content.PartnerPromo -%}
{%- assign ctas = Model.ContentItem.Content.CallToActions.ContentItems -%}
{%- assign partners = Model.ContentItem.Content.Partners.ContentItems -%}
<div class="grid gap-12 lg:grid-cols-2 lg:items-center lg:gap-16">
  <div>
    {%- if promo.Heading.Text and promo.Heading.Text != "" -%}
      <h2 class="text-[clamp(1.75rem,3.5vw,2.5rem)] leading-[1.1] tracking-tight text-white">{{ promo.Heading.Text }}</h2>
    {%- endif -%}
    {%- if promo.Intro.Html and promo.Intro.Html != "" -%}
      <div class="mt-5 max-w-md text-lg leading-relaxed text-pretty text-green-100/80">{{ promo.Intro.Html | raw }}</div>
    {%- endif -%}
    {%- if ctas.size > 0 -%}
      <div class="mt-8 flex flex-wrap gap-3">
        {%- for cta in ctas -%}
          {{ "Button" | shape_new: url: cta.CallToAction.Link.Url, text: cta.CallToAction.Link.Text, target: cta.CallToAction.Link.Target, variant: cta.CallToAction.Variant.Text | shape_render }}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
  {%- if partners.size > 0 -%}
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {%- for partner in partners -%}
        {%- assign alt = partner.DisplayText -%}
        {%- assign logoPath = partner.Partner.Logo.Paths.first -%}
        {%- assign link = partner.Partner.Link.Url -%}
        {%- if link and link != "" -%}
        <a href="{{ link | href }}" aria-label="{{ alt }}" class="flex aspect-square items-center justify-center rounded-xl bg-white/90 p-5 transition hover:bg-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">
          {%- if logoPath and logoPath != "" -%}<img src="{{ logoPath | asset_url }}" alt="{{ alt }}" loading="lazy" decoding="async" class="max-h-16 w-auto max-w-full object-contain">{%- endif -%}
        </a>
        {%- else -%}
        <div class="flex aspect-square items-center justify-center rounded-xl bg-white/90 p-5">
          {%- if logoPath and logoPath != "" -%}<img src="{{ logoPath | asset_url }}" alt="{{ alt }}" loading="lazy" decoding="async" class="max-h-16 w-auto max-w-full object-contain">{%- endif -%}
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>
