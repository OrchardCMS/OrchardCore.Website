{%- comment -%}
  Statistics. An optional heading + lead, then a row of statistic tiles (always dark-green so they
  read on any band). Stat Numbers may be a shortcode (e.g. [github_stars]). Band/anchor + theme come
  from the Block part; stack it with another same-background block to read as one section.
{%- endcomment -%}
{%- assign intro = Model.ContentItem.Content.BlockIntro -%}
{%- assign section = Model.ContentItem.Content.BlockPart -%}
{%- assign themeName = section.Theme.Text | default: "White" | downcase -%}
{%- assign anchor = section.AnchorId.Text -%}
{%- assign statistics = Model.ContentItem.Content.Stats.ContentItems -%}
{%- assign freshness = Model.ContentItem.Content.Freshness -%}
{%- assign lastCommitLabel = freshness.LastCommitLabel.Text -%}
{%- assign latestReleaseLabel = freshness.LatestReleaseLabel.Text -%}
{%- assign hasLastCommit = false -%}{%- if lastCommitLabel and lastCommitLabel != "" -%}{%- assign hasLastCommit = true -%}{%- endif -%}
{%- assign hasLatestRelease = false -%}{%- if latestReleaseLabel and latestReleaseLabel != "" -%}{%- assign hasLatestRelease = true -%}{%- endif -%}

<section {% if anchor and anchor != "" %}id="{{ anchor }}"{% endif %} class="theme-{{ themeName }}">
  <div class="mx-auto max-w-content px-6 band">

    {{ "BlockIntro" | shape_new: title: intro.Title.Text, lead: intro.Lead.Html, wrapperWidth: "mx-auto max-w-4xl", leadWidth: "max-w-2xl" | shape_render }}

    {%- if statistics.size > 0 -%}
      <dl class="mx-auto mt-10 grid max-w-4xl grid-cols-2 gap-4 lg:grid-cols-4">
        {%- for statistic in statistics -%}
          <div class="rounded-xl bg-green-900 p-5 text-center">
            <dd class="font-serif text-3xl text-green-100 sm:text-4xl">{{ statistic.Statistic.Number.Text | shortcode }}</dd>
            <dt class="mt-2 text-sm text-green-100/70">{{ statistic.Statistic.Label.Text }}</dt>
          </div>
        {%- endfor -%}
      </dl>
    {%- endif -%}

    {%- comment -%} Freshness line: editable labels + live GitHub values. [last_commit] renders the commit
      time as a localised "X ago" (Orchard Core TimeSpan shape) and [last_commit_message] the commit subject;
      [latest_release] the version and [latest_release_date] the publish date (DateTime shape, visitor's
      culture). Each half shows only if its label is set; the message/date show only when present. {%- endcomment -%}
    {%- assign statsItem = 'ocwebsitesitestatistics00' | content_item_id -%}
    {%- assign hasCommitMessage = false -%}{%- if statsItem.Content.SiteStatistics.LastCommitMessage.Text and statsItem.Content.SiteStatistics.LastCommitMessage.Text != "" -%}{%- assign hasCommitMessage = true -%}{%- endif -%}
    {%- assign hasReleaseDate = false -%}{%- if statsItem.Content.SiteStatistics.LatestReleaseDate.Text and statsItem.Content.SiteStatistics.LatestReleaseDate.Text != "" -%}{%- assign hasReleaseDate = true -%}{%- endif -%}
    {%- assign commitUrl = statsItem.Content.SiteStatistics.LastCommitUrl.Text -%}
    {%- if hasLastCommit or hasLatestRelease -%}
      {%- comment -%} On sm+ the line never wraps (sm:flex-nowrap); the commit-message chip is the only
        flexible part (min-w-0 + truncate), so a long message ellipsises to keep "Last commit …" and
        "Latest release …" on one line. On mobile it wraps to two lines and the chip truncates to fit. {%- endcomment -%}
      <p class="mx-auto mt-5 flex max-w-4xl flex-wrap items-center justify-center gap-x-3 gap-y-2 text-center text-sm text-ink-soft theme-dark:text-green-100/70 sm:flex-nowrap">
        {%- if hasLastCommit -%}<span class="flex min-w-0 items-center justify-center gap-x-2"><span class="shrink-0 whitespace-nowrap">{{ lastCommitLabel }} {{ '[last_commit]' | shortcode | raw }}</span>{%- if hasCommitMessage -%}{%- if commitUrl and commitUrl != "" -%}<a href="{{ commitUrl }}" target="_blank" rel="noopener" title="View this commit on GitHub" class="min-w-0 truncate rounded bg-cream-deep px-1.5 py-0.5 font-mono text-xs text-green-900 no-underline transition-colors hover:text-green-700 theme-dark:bg-white/10 theme-dark:text-green-100 theme-dark:hover:text-white">{{ '[last_commit_message]' | shortcode }}</a>{%- else -%}<code class="min-w-0 truncate rounded bg-cream-deep px-1.5 py-0.5 font-mono text-xs text-green-900 theme-dark:bg-white/10 theme-dark:text-green-100">{{ '[last_commit_message]' | shortcode }}</code>{%- endif -%}{%- endif -%}</span>{%- endif -%}
        {%- if hasLastCommit and hasLatestRelease -%}<span class="hidden shrink-0 text-rule sm:inline" aria-hidden="true">&middot;</span>{%- endif -%}
        {%- if hasLatestRelease -%}<span class="shrink-0 whitespace-nowrap">{{ latestReleaseLabel }} <strong class="font-semibold text-green-900 theme-dark:text-white">{{ '[latest_release]' | shortcode }}</strong>{%- if hasReleaseDate -%}, {{ '[latest_release_date]' | shortcode | raw }}{%- endif -%}</span>{%- endif -%}
      </p>
    {%- endif -%}

  </div>
</section>
