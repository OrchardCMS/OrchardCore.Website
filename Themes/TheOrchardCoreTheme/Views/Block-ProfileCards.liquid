{%- comment -%}
  Profile Cards. An optional heading + lead, then a grid of large square photo cards — each a person's
  photo (or GitHub avatar), name, role, and GitHub/LinkedIn icon links — plus the shared BlockActions
  closing row. Band/anchor + theme come from the Block part. Reusable for speakers, team, etc.
{%- endcomment -%}
{%- assign intro = Model.ContentItem.Content.BlockIntro -%}
{%- assign section = Model.ContentItem.Content.BlockPart -%}
{%- assign themeName = section.Theme.Text | default: "White" | downcase -%}
{%- assign anchor = section.AnchorId.Text -%}
{%- assign profiles = Model.ContentItem.Content.Profiles.ContentItems -%}
{%- assign blockActions = Model.ContentItem.Content.BlockActionsPart -%}

<section {% if anchor and anchor != "" %}id="{{ anchor }}"{% endif %} class="theme-{{ themeName }}">
  <div class="mx-auto max-w-content px-6 band">

    {{ "BlockIntro" | shape_new: title: intro.Title.Text, lead: intro.Lead.Html | shape_render }}

    {%- if profiles.size > 0 -%}
      <div class="mt-12 grid grid-cols-2 gap-x-5 gap-y-10 sm:grid-cols-3 lg:grid-cols-5">
        {%- for profile in profiles -%}
          {%- assign role = profile.Profile.Role.Text -%}
          {%- assign github = profile.Profile.GitHubUrl.Text -%}
          {%- assign linkedin = profile.Profile.LinkedInUrl.Text -%}
          {%- assign hasSocial = false -%}
          {%- if github and github != "" -%}{%- assign hasSocial = true -%}{%- endif -%}
          {%- if linkedin and linkedin != "" -%}{%- assign hasSocial = true -%}{%- endif -%}
          {%- comment -%} Full-height flex column so the social row (mt-auto) sits at the bottom and the
            icons align across cards regardless of how many lines the role wraps to. {%- endcomment -%}
          <div class="flex h-full flex-col text-center">
            {{ "ProfileAvatar" | shape_new: item: profile, width: 240, sizes: "(min-width:1024px) 210px, (min-width:640px) 30vw, 45vw", class: "aspect-square w-full rounded-xl object-cover bg-cream theme-dark:bg-white/5" | shape_render }}
            <h3 class="mt-4 text-lg text-green-900 theme-dark:text-white">{{ profile.DisplayText }}</h3>
            {%- if role and role != "" -%}<p class="mt-1 text-sm leading-relaxed text-balance text-ink-soft theme-dark:text-green-100/70">{{ role }}</p>{%- endif -%}
            {%- if hasSocial -%}<div class="mt-auto pt-3 flex items-center justify-center gap-1">{{ "SocialLinks" | shape_new: github: github, linkedin: linkedin, name: profile.DisplayText | shape_render }}</div>{%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Closing actions row: copy from BlockActionsPart, buttons from the CallToActions bag. {%- endcomment -%}
    {%- capture actionsHtml -%}
      {%- for callToAction in Model.ContentItem.Content.CallToActions.ContentItems -%}
        {{ "Button" | shape_new: url: callToAction.CallToAction.Link.Url, text: callToAction.CallToAction.Link.Text, target: callToAction.CallToAction.Link.Target, variant: callToAction.CallToAction.Variant.Text | shape_render }}
      {%- endfor -%}
    {%- endcapture -%}
    {{ "BlockActions" | shape_new: heading: blockActions.Heading.Text, text: blockActions.Text.Html, actions: actionsHtml, maxWidth: "max-w-none" | shape_render }}

  </div>
</section>
