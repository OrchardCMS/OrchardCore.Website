@*
    Shared call-to-action button. Invoked from block templates with:
      @await DisplayAsync(await New.Button(Url: ..., Text: ..., Target: ..., Variant: ...))
    (or, from a Liquid caller, {{ "Button" | shape_new: url: ..., text: ..., target: ..., variant: ... | shape_render }})
    The editor picks intent only (Primary / Secondary / Ghost). The on-dark treatment is applied
    automatically by the block "theme": a button inside a `.theme-dark` section picks up the
    `theme-dark:` utility overrides below. No "on-dark" variant to choose, no branching.
*@
@{
    string url = Model.Url;
}
@if (!string.IsNullOrEmpty(url))
{
    string label = Model.Text;
    if (string.IsNullOrEmpty(label))
    {
        label = url;
    }

    string variant = Model.Variant;
    if (string.IsNullOrEmpty(variant))
    {
        variant = "Primary";
    }

    string? target = Model.Target;
    if (string.IsNullOrEmpty(target))
    {
        target = null;
    }

    const string baseCls = "inline-block text-sm text-center font-semibold transition focus-visible:outline-2 focus-visible:outline-offset-2";
    var cls = variant switch
    {
        "Secondary" => "rounded-md px-5 py-3 bg-green-100 text-green-800 hover:bg-green-200 focus-visible:outline-green-700 theme-dark:bg-white/10 theme-dark:text-white theme-dark:ring-1 theme-dark:ring-white/20 theme-dark:hover:bg-white/15 theme-dark:focus-visible:outline-white",
        "Ghost" => "underline underline-offset-2 text-green-700 decoration-green-700/30 hover:decoration-green-700 focus-visible:outline-green-700 theme-dark:text-accent-bright theme-dark:decoration-accent-bright/40 theme-dark:hover:decoration-accent-bright theme-dark:focus-visible:outline-white",
        _ => "rounded-md px-5 py-3 bg-green-600 text-white hover:bg-green-700 focus-visible:outline-green-700 theme-dark:bg-accent-bright theme-dark:text-green-900 theme-dark:hover:bg-accent-bright-hover theme-dark:focus-visible:outline-accent-bright",
    };

    <a href="@Url.Content(url)" class="@baseCls @cls" target="@target" rel="@(target is null ? null : "noopener")">@label</a>
}
