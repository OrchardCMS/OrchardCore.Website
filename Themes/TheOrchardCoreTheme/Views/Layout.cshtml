@using Microsoft.AspNetCore.Html
@using OrchardCore.ContentManagement
@inject IContentManager ContentManager
<!DOCTYPE html>
<html lang="@Orchard.CultureName()">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@RenderTitleSegments(Site.SiteName, "before", new HtmlString(" - "))</title>

    <resources type="Meta" />

    <link rel="icon" type="image/webp" href="@Url.Content("~/TheOrchardCoreTheme/assets/orchard-core-symbol-logo-color.webp")">
    <link rel="apple-touch-icon" href="@Url.Content("~/TheOrchardCoreTheme/assets/orchard-core-symbol-logo-color.webp")">

    @* Self-hosted fonts — the @@font-face rules live in the compiled site.css; no request to
       fonts.googleapis.com. Preload the two above-the-fold latin files (Inter body, Bitter headings) so
       they fetch alongside the CSS; latin-ext + JetBrains Mono load on demand. *@
    <link rel="preload" href="@Url.Content("~/TheOrchardCoreTheme/fonts/inter-latin.woff2")" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="@Url.Content("~/TheOrchardCoreTheme/fonts/bitter-latin.woff2")" as="font" type="font/woff2" crossorigin>

    @* Compiled Tailwind CSS (Assets/Styles/site.css -> wwwroot/css/site.css). *@
    <style asp-name="TheOrchardCoreTheme" asp-append-version="true"></style>

    @* Apply the saved theme before paint so there is no flash of the wrong mode. *@
    <script>
      document.documentElement.className += ' js';
      (function () {
        var theme = null;
        try { theme = localStorage.getItem('ocTheme'); } catch (error) {}
        if (!theme) { theme = (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) ? 'dark' : 'light'; }
        if (theme === 'dark') { document.documentElement.classList.add('dark'); }
      })();
    </script>

    <resources type="HeadLink" />
    <resources type="Stylesheet" />
    <resources type="HeadScript" />
    @await RenderSectionAsync("HeadMeta", required: false)
</head>
<body dir="@Orchard.CultureDir()" class="bg-white text-ink">

@{
    // The primary nav is built from the CURRENT page's section blocks that opt in
    // (BlockPart.ShowInNav + NavText), each linking to its section AnchorId, in on-page order. The
    // Layout has no Model.ContentItem, so load the current (culture-specific) page from the matched
    // route value. navLinks stays empty for non-LandingPage pages, so the nav loops render nothing.
    // One nav link per opted-in block, reused by the desktop nav and the mobile menu.
    var navLinks = new List<(string Anchor, string Text)>();
    if (Context.Request.RouteValues["contentItemId"] is string contentItemId)
    {
        var current = await ContentManager.GetAsync(contentItemId);
        if (current?.ContentType == "LandingPage")
        {
            foreach (var block in current.Get<BagPart>("Sections")?.ContentItems ?? [])
            {
                var nav = block.Get<ContentPart>("BlockPart");
                if (nav?.Get<BooleanField>("ShowInNav")?.Value == true)
                {
                    var navText = nav.Get<TextField>("NavText")?.Text;
                    var anchorId = nav.Get<TextField>("AnchorId")?.Text;
                    if (!string.IsNullOrEmpty(navText) && !string.IsNullOrEmpty(anchorId))
                    {
                        navLinks.Add((anchorId!, navText!));
                    }
                }
            }
        }
    }
}

<header id="siteHeader" class="sticky top-0 z-40 transition-shadow duration-300">
  <div class="mx-auto flex max-w-content items-center justify-between px-6 py-3.5">
    <div class="flex items-center gap-8 lg:gap-10">
