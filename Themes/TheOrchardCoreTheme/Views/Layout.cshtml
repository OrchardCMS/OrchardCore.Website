          </g>
        </svg>
      </a>

      <nav aria-label="Primary" class="hidden lg:block">
        <ul class="flex items-center gap-7 text-sm font-medium">
          @foreach (var (navAnchor, navText) in navLinks)
          {
            <li><a class="nav-link transition-colors hover:text-leaf focus-visible:outline-2 focus-visible:outline-green-700" href="#@navAnchor" data-spy="@navAnchor">@navText</a></li>
          }
        </ul>
      </nav>
    </div>

    <div class="flex items-center gap-4">
      @* Social icons are content-managed: a SocialLinks widget placed (via Layers) in the
         site-wide 'Header' zone, on the 'Always' layer. Manage under Design → Widgets. *@
      @await RenderSectionAsync("Header", required: false)

      <button id="themeToggle" type="button" role="switch" aria-checked="false" aria-label="Switch to dark mode" class="relative inline-flex h-6 w-11 shrink-0 items-center rounded-full border transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-700">
        <svg aria-hidden="true" class="pointer-events-none absolute left-[6px] top-1/2 h-3 w-3 -translate-y-1/2 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg aria-hidden="true" class="pointer-events-none absolute right-[6px] top-1/2 h-3 w-3 -translate-y-1/2 text-ink-soft" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <span class="theme-knob absolute left-0.5 top-1/2 h-4 w-4 rounded-full shadow transition-transform"></span>
      </button>

      <button id="menuBtn" type="button" aria-expanded="false" aria-controls="mobileNav" class="lg:hidden -mr-2 p-2 text-green-900 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-700 theme-dark:text-white">
        <span class="sr-only">Menu</span>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" class="hidden"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>
  </div>

</header>

@* Mobile menu (does not push content): a dimmed/blurred backdrop over the page + a panel
   that drops below the sticky header and scrolls if taller than the viewport. theme.js sets --header-h
   to the header height and locks body scroll while open. Closes on backdrop click, Escape, or a link. *@
<div id="mobileNavBackdrop" data-menu-close class="hidden lg:hidden fixed inset-0 z-30 bg-ink/60 backdrop-blur-sm"></div>
<nav id="mobileNav" aria-label="Primary" class="hidden lg:hidden fixed inset-x-0 top-[var(--header-h)] z-40 max-h-[calc(100dvh_-_var(--header-h))] overflow-y-auto overscroll-contain border-t border-rule bg-cream shadow-soft">
  <ul class="mx-auto flex max-w-content flex-col px-6 py-2 text-base font-medium">
    @foreach (var (navAnchor, navText) in navLinks)
    {
      <li><a class="nav-link block py-3" href="#@navAnchor" data-spy="@navAnchor">@navText</a></li>
    }
  </ul>
</nav>

<main id="main">
    @await RenderSectionAsync("Messages", required: false)
    @await RenderBodyAsync()
</main>

@* Footer is content-managed: PartnerPromo / Brand / LinkColumn widgets placed (via Layers) in
   the "Footer Top" and "Footer Bottom" zones below, on the English/French culture layers. This <footer>
   shell owns the fixed layout (the dark band + the two-row grid); the widgets fill it. `theme-dark` makes
   the shared Button / SocialLinks shapes use their on-dark styling. *@
<footer class="theme-dark bg-green-900 text-white">
  <div class="mx-auto max-w-content px-6 py-16">
    @await RenderSectionAsync("Footer Top", required: false)
    <div class="mt-16 grid gap-10 border-t border-white/10 pt-12 sm:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr] lg:gap-12">
      @await RenderSectionAsync("Footer Bottom", required: false)
    </div>
  </div>
</footer>

@await RenderSectionAsync("Footer", required: false)

@* Shared photo lightbox: Gallery blocks render [data-photo] buttons; theme.js opens this
   singleton modal with the clicked image. Close with the backdrop, the button, or Escape. *@
<div id="photoModal" class="fixed inset-0 z-50 hidden" role="dialog" aria-modal="true" aria-label="Photo">
  <div data-photo-close class="absolute inset-0 bg-ink/80 backdrop-blur-sm"></div>
  <button type="button" data-photo-close aria-label="Close" class="absolute right-4 top-4 z-10 grid h-10 w-10 place-items-center rounded-full bg-white/10 text-2xl leading-none text-white ring-1 ring-white/20 backdrop-blur transition hover:bg-white/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">&times;</button>
  <div class="pointer-events-none absolute inset-0 flex items-center justify-center p-4 sm:p-10">
    <img id="photoModalImg" src="" alt="" class="max-h-[85vh] max-w-full rounded-xl object-contain shadow-soft">
  </div>
</div>

<script asp-name="TheOrchardCoreTheme" at="Foot" asp-append-version="true"></script>
<resources type="FootScript" />
</body>
</html>
