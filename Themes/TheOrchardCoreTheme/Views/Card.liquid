{%- comment -%}
  Shared card. Renders one Card content item:
    {{ "Card" | shape_new: item: <card content item> | shape_render }}
  (shape_new PascalCases the arg, so it is read as Model.Item.) A card is title + body, with an
  optional meta line and an optional button (Link + Variant, via the shared Button shape).
  The body is run through `| shortcode`, so editors can drop tokens in it — e.g. [contributor_avatars]
  for the "built by the community" avatar row (defined in the module's automation recipe).
  The shell is band-aware (white normally, cream on a white band, translucent on a dark band) so the
  same card reads on every section background.
{%- endcomment -%}
{%- assign item = Model.Item -%}
{%- assign card = item.Card -%}
{%- assign actions = item.CallToActions.ContentItems -%}
<div class="flex h-full flex-col rounded-xl bg-white p-6 theme-white:bg-cream theme-dark:bg-white/5">
  <h3 class="text-lg text-green-900 theme-dark:text-white">{{ item.DisplayText }}</h3>
  {%- if card.Meta.Text and card.Meta.Text != "" -%}
    <p class="mt-1 text-sm font-semibold text-green-700 theme-dark:text-accent-bright">{{ card.Meta.Text }}</p>
  {%- endif -%}
  {%- if card.Body.Html and card.Body.Html != "" -%}
    <div class="prose mt-2 flex-1">{{ card.Body.Html | shortcode | raw }}</div>
  {%- else -%}
    <div class="flex-1"></div>
  {%- endif -%}

  {%- if actions.size > 0 -%}
    <div class="mt-6 flex flex-wrap items-center gap-3">
      {%- for cta in actions -%}
        {{ "Button" | shape_new: url: cta.CallToAction.Link.Url, text: cta.CallToAction.Link.Text, target: cta.CallToAction.Link.Target, variant: cta.CallToAction.Variant.Text | shape_render }}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>
