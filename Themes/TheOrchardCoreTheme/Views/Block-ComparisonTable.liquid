{%- comment -%}
  Comparison Table. Heading + lead, then a static table: a row-label column + one column per
  ComparisonColumn (mark one Highlighted for the green treatment), and one ComparisonRow per row
  whose Cells line up with the columns by order (cell i -> column i). Horizontal scroll on mobile,
  no JavaScript. Closes with the shared BlockActions row. Band/anchor + theme come from the Section.
  Cell/header colours are token-backed utilities that the html.dark remaps adapt for dark mode.
{%- endcomment -%}
{%- assign intro = Model.ContentItem.Content.BlockIntro -%}
{%- assign section = Model.ContentItem.Content.BlockPart -%}
{%- assign themeName = section.Theme.Text | default: "White" | downcase -%}
{%- assign anchor = section.AnchorId.Text -%}
{%- assign columns = Model.ContentItem.Content.Columns.ContentItems -%}
{%- assign rows = Model.ContentItem.Content.Rows.ContentItems -%}
{%- assign blockActions = Model.ContentItem.Content.BlockActionsPart -%}

<section {% if anchor and anchor != "" %}id="{{ anchor }}"{% endif %} class="theme-{{ themeName }}">
  <div class="mx-auto max-w-content px-6 band">

    {{ "BlockIntro" | shape_new: title: intro.Title.Text, lead: intro.Lead.Html | shape_render }}

    {%- if columns.size > 0 and rows.size > 0 -%}
      <div class="mt-12 overflow-x-auto">
        <table class="w-full min-w-[680px] table-fixed border-separate border-spacing-x-0 border-spacing-y-0.5 text-left align-top text-sm">
          <thead>
            <tr>
              <th scope="col" class="w-1/5 p-5"><span class="sr-only">Feature</span></th>
              {%- for column in columns -%}
                {%- assign highlighted = false -%}{%- if column.ComparisonColumn.Highlighted.Text == "Yes" -%}{%- assign highlighted = true -%}{%- endif -%}
                <th scope="col" class="p-5 font-serif text-base text-green-900{% if highlighted %} rounded-t-xl bg-green-100{% endif %}">{{ column.DisplayText }}</th>
              {%- endfor -%}
            </tr>
          </thead>
          <tbody>
            {%- for row in rows -%}
              {%- assign isLastRow = forloop.last -%}
              {%- assign cells = row.Cells.ContentItems -%}
              <tr>
                <th scope="row" class="rounded-l-xl bg-white p-5 font-semibold text-green-900">{{ row.DisplayText }}</th>
                {%- for column in columns -%}
                  {%- assign highlighted = false -%}{%- if column.ComparisonColumn.Highlighted.Text == "Yes" -%}{%- assign highlighted = true -%}{%- endif -%}
                  {%- assign cell = cells[forloop.index0] -%}
                  <td class="p-5 leading-relaxed{% if highlighted %} bg-green-200 text-green-900{% if isLastRow %} rounded-b-xl{% endif %}{% else %} bg-white text-ink-soft{% endif %}{% if forloop.last %} rounded-r-xl{% endif %}">{{ cell.DisplayText }}</td>
                {%- endfor -%}
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    {%- endif -%}

    {%- comment -%} Closing actions row: copy from BlockActionsPart, buttons from the CallToActions bag. {%- endcomment -%}
    {%- capture actionsHtml -%}
      {%- for callToAction in Model.ContentItem.Content.CallToActions.ContentItems -%}
        {{ "Button" | shape_new: url: callToAction.CallToAction.Link.Url, text: callToAction.CallToAction.Link.Text, target: callToAction.CallToAction.Link.Target, variant: callToAction.CallToAction.Variant.Text | shape_render }}
      {%- endfor -%}
    {%- endcapture -%}
    {{ "BlockActions" | shape_new: heading: blockActions.Heading.Text, text: blockActions.Text.Html, actions: actionsHtml, maxWidth: "max-w-none" | shape_render }}

  </div>
</section>
