{%- comment -%}
  Schedule. An optional heading + lead, then the groups (a day / track / section each) stacked
  full-width, each with a heading + optional subheading and a list of sessions (rendered by the
  shared ScheduleSession shape), plus the shared BlockActions closing row. Band/anchor + theme come
  from the Block part. Generic: reuse for event days, course weeks, roadmap phases, a single agenda.
{%- endcomment -%}
{%- assign intro = Model.ContentItem.Content.BlockIntro -%}
{%- assign section = Model.ContentItem.Content.BlockPart -%}
{%- assign themeName = section.Theme.Text | default: "White" | downcase -%}
{%- assign anchor = section.AnchorId.Text -%}
{%- assign groups = Model.ContentItem.Content.Groups.ContentItems -%}
{%- assign blockActions = Model.ContentItem.Content.BlockActionsPart -%}

<section {% if anchor and anchor != "" %}id="{{ anchor }}"{% endif %} class="theme-{{ themeName }}">
  <div class="mx-auto max-w-content px-6 band">

    {{ "BlockIntro" | shape_new: title: intro.Title.Text, lead: intro.Lead.Html, wrapperWidth: "mx-auto max-w-4xl" | shape_render }}

    {%- if groups.size > 0 -%}
      <div class="mx-auto mt-10 max-w-4xl space-y-12">
        {%- for group in groups -%}
          {%- assign heading = group.ScheduleGroup.Heading.Text -%}
          {%- assign subheading = group.ScheduleGroup.Subheading.Text -%}
          {%- assign sessions = group.Sessions.ContentItems -%}
          <div>
            {%- if heading and heading != "" -%}
              <div class="pb-3">
                <h3 class="text-2xl text-green-900 theme-dark:text-white">{{ heading }}</h3>
                {%- if subheading and subheading != "" -%}<p class="mt-0.5 text-sm text-ink-soft theme-dark:text-green-100/70">{{ subheading }}</p>{%- endif -%}
              </div>
            {%- endif -%}
            {%- if sessions.size > 0 -%}
              <ul class="space-y-1">
                {%- for session in sessions -%}<li>{{ "ScheduleSession" | shape_new: item: session | shape_render }}</li>{%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Closing actions row: copy from BlockActionsPart, buttons from the CallToActions bag. {%- endcomment -%}
    {%- capture actionsHtml -%}
      {%- for callToAction in Model.ContentItem.Content.CallToActions.ContentItems -%}
        {{ "Button" | shape_new: url: callToAction.CallToAction.Link.Url, text: callToAction.CallToAction.Link.Text, target: callToAction.CallToAction.Link.Target, variant: callToAction.CallToAction.Variant.Text | shape_render }}
      {%- endfor -%}
    {%- endcapture -%}
    {{ "BlockActions" | shape_new: heading: blockActions.Heading.Text, text: blockActions.Text.Html, actions: actionsHtml, maxWidth: "mx-auto max-w-4xl" | shape_render }}

  </div>
</section>
