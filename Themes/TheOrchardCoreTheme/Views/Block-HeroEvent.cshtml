@*
    Hero (Event). The event page's opening section: copy beside a date poster (month, day
    range, year, place). The outer band + anchor come from the shared Block. The block's
    background is its "theme": the wrapper carries a `theme-<name>` class and per-theme styling
    is applied with `theme-*:` utility variants (no on-dark branching in the view).
*@
@{
    var item = (ContentItem)Model.ContentItem;
    var hero = item.Get<ContentPart>("HeroEvent");
    var section = item.Get<ContentPart>("BlockPart");
    var theme = section?.Get<TextField>("Theme")?.Text;
    var themeName = (string.IsNullOrEmpty(theme) ? "White" : theme).ToLowerInvariant();
    var anchor = section?.Get<TextField>("AnchorId")?.Text;
    var poster = hero?.Get<MediaField>("PosterImage")?.Paths?.FirstOrDefault();
    var callToActions = item.Get<BagPart>("CallToActions")?.ContentItems ?? [];
    var lead = hero?.Get<HtmlField>("Lead")?.Html;
    var announcement = hero?.Get<LinkField>("Announcement");
    var month = hero?.Get<TextField>("EventMonth")?.Text;
    var days = hero?.Get<TextField>("EventDays")?.Text;
    var year = hero?.Get<TextField>("EventYear")?.Text;
    var place = hero?.Get<TextField>("EventPlace")?.Text;
    // The date card renders off the date fields; the PosterImage is only its optional backdrop.
    var hasDateCard = !string.IsNullOrEmpty(month) || !string.IsNullOrEmpty(days);
    var hasYear = !string.IsNullOrEmpty(year);
    var hasPlace = !string.IsNullOrEmpty(place);
}
<section id="@(string.IsNullOrEmpty(anchor) ? null : anchor)" class="relative overflow-hidden theme-@themeName">
    <div class="relative z-10 mx-auto max-w-content px-6 pt-10 pb-16 sm:pt-14 sm:pb-20">
        <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">

            @* Copy column. *@
            <div>
                @await DisplayAsync(await New.Announcement(Url: announcement?.Url, Text: announcement?.Text, Badge: hero?.Get<TextField>("AnnouncementBadge")?.Text, Message: hero?.Get<TextField>("AnnouncementText")?.Text))

                <h1 class="mt-5 text-[clamp(2.25rem,4.5vw,3.5rem)] leading-[1.08] tracking-[-0.02em] text-green-900 theme-dark:text-white">@item.DisplayText</h1>

                @if (!string.IsNullOrEmpty(lead))
                {
                    <div class="prose prose-lg mt-5 max-w-xl text-pretty">@Html.Raw(lead)</div>
                }

                @if (callToActions.Count > 0)
                {
                    <div class="mt-8 flex flex-wrap items-center gap-4">
                        @foreach (var cta in callToActions)
                        {
                            var callToAction = cta.Get<ContentPart>("CallToAction");
                            var link = callToAction?.Get<LinkField>("Link");
                            @await DisplayAsync(await New.Button(Url: link?.Url, Text: link?.Text, Target: link?.Target, Variant: callToAction?.Get<TextField>("Variant")?.Text))
                        }
                    </div>
                }
            </div>

            @* Date poster column: the date over the image with a green gradient, filling the column —
               matches the v1 event hero (aspect-[4/3], no max-width). With no PosterImage set (e.g. a
               past event with no venue photo) the same card keeps its ratio on the flat green band. *@
            @if (hasDateCard)
            {
                <div class="relative flex aspect-[4/3] flex-col items-center justify-center overflow-hidden rounded-2xl bg-green-900 text-center shadow-soft">
                    @if (poster is not null)
                    {
                        @await DisplayAsync(await New.Image(Path: poster, Alt: "", AriaHidden: true, Width: 1000, Height: 750, Sizes: "(min-width:1024px) 45vw, 90vw", Eager: true, Priority: "high", Class: "pointer-events-none absolute inset-0 h-full w-full select-none object-cover"))
                        <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-green-900 via-green-900/35 to-transparent" aria-hidden="true"></div>
                    }
                    <div class="relative z-10 px-6 text-white">
                        @if (!string.IsNullOrEmpty(month))
                        {
                            <span class="block font-serif text-xl">@month</span>
                        }
                        @if (!string.IsNullOrEmpty(days))
                        {
                            <span class="block font-serif text-6xl leading-none sm:text-7xl">@days</span>
                        }
                        @if (hasYear || hasPlace)
                        {
                            <span class="mt-3 block text-sm font-semibold">@year@(hasYear && hasPlace ? " · " : "")@place</span>
                        }
                    </div>
                </div>
            }

        </div>
    </div>
</section>
