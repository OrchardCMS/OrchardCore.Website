{%- comment -%}
  Hero (Event). The event page's opening section: copy beside a date poster (month, day
  range, year, place). The outer band + anchor come from the shared Block. The block's
  background is its "theme": the wrapper carries a `theme-<name>` class and per-theme styling
  is applied with `theme-*:` utility variants (no on-dark branching in Liquid).
{%- endcomment -%}
{%- assign hero = Model.ContentItem.Content.HeroEvent -%}
{%- assign section = Model.ContentItem.Content.BlockPart -%}
{%- assign themeName = section.Theme.Text | default: "White" | downcase -%}
{%- assign anchor = section.AnchorId.Text -%}
{%- assign poster = hero.PosterImage.Paths.first -%}

{%- capture announcementHtml -%}{{ "Announcement" | shape_new: url: hero.Announcement.Url, text: hero.Announcement.Text, badge: hero.AnnouncementBadge.Text, message: hero.AnnouncementText.Text | shape_render }}{%- endcapture -%}

{%- assign callToActions = Model.ContentItem.Content.CallToActions.ContentItems -%}
{%- assign hasPoster = false -%}
{%- if hero.EventMonth.Text and hero.EventMonth.Text != "" -%}{%- assign hasPoster = true -%}{%- endif -%}
{%- if hero.EventDays.Text and hero.EventDays.Text != "" -%}{%- assign hasPoster = true -%}{%- endif -%}

<section {% if anchor and anchor != "" %}id="{{ anchor }}"{% endif %} class="relative overflow-hidden theme-{{ themeName }}">
  <div class="relative z-10 mx-auto max-w-content px-6 pt-10 pb-16 sm:pt-14 sm:pb-20">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">

      {%- comment -%} Copy column. {%- endcomment -%}
      <div>
        {{ announcementHtml }}

        <h1 class="mt-5 text-[clamp(2.25rem,4.5vw,3.5rem)] leading-[1.08] tracking-[-0.02em] text-green-900 theme-dark:text-white">{{ Model.ContentItem.DisplayText }}</h1>

        {%- if hero.Lead.Html and hero.Lead.Html != "" -%}
          <div class="prose prose-lg mt-5 max-w-xl text-pretty">{{ hero.Lead.Html | raw }}</div>
        {%- endif -%}

        {%- if callToActions.size > 0 -%}
          <div class="mt-8 flex flex-wrap items-center gap-4">
            {%- for callToAction in callToActions -%}
              {{ "Button" | shape_new: url: callToAction.CallToAction.Link.Url, text: callToAction.CallToAction.Link.Text, target: callToAction.CallToAction.Link.Target, variant: callToAction.CallToAction.Variant.Text | shape_render }}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Date poster column: a photo poster (the date over the image with a green gradient, same
        treatment as EventPromo) when a PosterImage is set, otherwise the plain cream date card. {%- endcomment -%}
      {%- if hasPoster -%}
        {%- if poster -%}
          {%- comment -%} Photo date poster: the date over the image with a green gradient, filling the
            column — matches the v1 event hero (aspect-[4/3], no max-width). {%- endcomment -%}
          <div class="relative flex aspect-[4/3] flex-col items-center justify-center overflow-hidden rounded-2xl bg-green-900 text-center shadow-soft">
            {{ "Image" | shape_new: path: poster, alt: "", ariaHidden: true, width: 1000, height: 750, sizes: "(min-width:1024px) 45vw, 90vw", eager: true, priority: "high", class: "pointer-events-none absolute inset-0 h-full w-full select-none object-cover" | shape_render }}
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-green-900 via-green-900/35 to-transparent" aria-hidden="true"></div>
            <div class="relative z-10 px-6 text-white">
              {%- if hero.EventMonth.Text and hero.EventMonth.Text != "" -%}<span class="block font-serif text-xl">{{ hero.EventMonth.Text }}</span>{%- endif -%}
              {%- if hero.EventDays.Text and hero.EventDays.Text != "" -%}<span class="block font-serif text-6xl leading-none sm:text-7xl">{{ hero.EventDays.Text }}</span>{%- endif -%}
              {%- assign hasYear = false -%}{%- if hero.EventYear.Text and hero.EventYear.Text != "" -%}{%- assign hasYear = true -%}{%- endif -%}
              {%- assign hasPlace = false -%}{%- if hero.EventPlace.Text and hero.EventPlace.Text != "" -%}{%- assign hasPlace = true -%}{%- endif -%}
              {%- if hasYear or hasPlace -%}<span class="mt-3 block text-sm font-semibold">{{ hero.EventYear.Text }}{% if hasYear and hasPlace %} &middot; {% endif %}{{ hero.EventPlace.Text }}</span>{%- endif -%}
            </div>
          </div>
        {%- else -%}
          {%- comment -%} No photo: the compact cream date card (aligned to the end of the column). {%- endcomment -%}
          <div class="lg:justify-self-end">
            <div class="mx-auto w-full max-w-xs rounded-2xl border p-8 text-center shadow-soft border-rule bg-cream text-green-900 theme-dark:border-white/15 theme-dark:bg-white/5 theme-dark:text-white">
              {%- if hero.EventMonth.Text and hero.EventMonth.Text != "" -%}<div class="eyebrow text-ink-soft theme-dark:text-green-100/80">{{ hero.EventMonth.Text }}</div>{%- endif -%}
              {%- if hero.EventDays.Text and hero.EventDays.Text != "" -%}<div class="mt-2 font-serif text-6xl font-semibold tracking-tight">{{ hero.EventDays.Text }}</div>{%- endif -%}
              {%- if hero.EventYear.Text and hero.EventYear.Text != "" -%}<div class="mt-1 text-lg">{{ hero.EventYear.Text }}</div>{%- endif -%}
              {%- if hero.EventPlace.Text and hero.EventPlace.Text != "" -%}<div class="mt-3 text-ink-soft theme-dark:text-green-100/80">{{ hero.EventPlace.Text }}</div>{%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endif -%}

    </div>
  </div>
</section>
