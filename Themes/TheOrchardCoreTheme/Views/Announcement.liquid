{%- comment -%}
  Announcement banner shape, shared by the hero blocks. Invoked with:
    {{ "Announcement" | shape_new: url: ..., text: ..., badge: ..., message: ... | shape_render }}
  - url     : the link target; the whole banner renders only when this is set
  - text    : the link label (e.g. "See details")
  - badge   : the badge chip text (e.g. "Event")
  - message : the message between the badge and the link
  The colours adapt to the block theme automatically via `theme-dark:` overrides (the
  banner sits inside a `.theme-<name>` section). Each of badge / message / text renders
  only when present. Note: shape_new PascalCases the argument names, so they are read here
  as Model.Url / Model.Text / Model.Badge / Model.Message.
{%- endcomment -%}
{%- if Model.Url and Model.Url != "" -%}
  <a href="{{ Model.Url | href }}" class="group mb-7 inline-flex flex-wrap items-center gap-x-2.5 gap-y-1 rounded-md border py-1 pl-1.5 pr-3.5 text-sm font-medium transition focus-visible:outline-2 focus-visible:outline-offset-2 border-rule bg-cream text-green-900 hover:border-green-600 focus-visible:outline-green-700 theme-dark:border-white/15 theme-dark:bg-white/5 theme-dark:text-green-100 theme-dark:hover:border-white/30 theme-dark:hover:bg-white/10 theme-dark:focus-visible:outline-accent-bright">
    {%- if Model.Badge and Model.Badge != "" -%}
      <span class="rounded-sm px-2 py-0.5 text-xs font-semibold uppercase tracking-wide bg-green-600 text-white theme-dark:bg-accent-bright theme-dark:text-green-900">{{ Model.Badge }}</span>
    {%- endif -%}
    {%- if Model.Message and Model.Message != "" -%}
      <span>{{ Model.Message }}</span>
    {%- endif -%}
    {%- if Model.Text and Model.Text != "" -%}
      {%- comment -%} The whole chip is the link, so on the narrowest screens the explicit
        label is redundant and only causes an orphaned wrap line — hide it below sm. {%- endcomment -%}
      <span class="hidden font-semibold underline underline-offset-2 text-green-700 decoration-green-700/30 group-hover:decoration-green-700 theme-dark:text-accent-bright theme-dark:decoration-accent-bright/40 theme-dark:group-hover:decoration-accent-bright sm:inline">{{ Model.Text }}</span>
    {%- endif -%}
  </a>
{%- endif -%}
