{%- comment -%}
  Shared section intro (heading + lead), rendered from the attachable BlockIntro part. Invoked with:
    {{ "BlockIntro" | shape_new: title: intro.Title.Text, lead: intro.Lead.Html | shape_render }}
  Optional args (shape_new PascalCases them → Model.WrapperWidth / Model.LeadWidth):
    wrapperWidth — the wrapper's max-width utilities (default "max-w-3xl"; centred grids pass "mx-auto max-w-4xl")
    leadWidth    — an extra max-width on the lead (e.g. "max-w-2xl"); omit for full wrapper width.
  Renders nothing when both title and lead are blank; the heading is hidden when the title is blank.
{%- endcomment -%}
{%- assign wrapper = Model.WrapperWidth -%}
{%- if wrapper == nil or wrapper == "" -%}{%- assign wrapper = "max-w-3xl" -%}{%- endif -%}
{%- assign leadWidth = Model.LeadWidth -%}
{%- assign hasTitle = false -%}{%- if Model.Title and Model.Title != "" -%}{%- assign hasTitle = true -%}{%- endif -%}
{%- assign hasLead = false -%}{%- if Model.Lead and Model.Lead != "" -%}{%- assign hasLead = true -%}{%- endif -%}
{%- if hasTitle or hasLead -%}
  <div class="{{ wrapper }}">
    {%- if hasTitle -%}
      <h2 class="text-[clamp(2rem,4.5vw,3.25rem)] leading-[1.1] tracking-tight text-green-900 theme-dark:text-white">{{ Model.Title }}</h2>
    {%- endif -%}
    {%- if hasLead -%}
      <div class="prose prose-lg mt-6 text-pretty{% if leadWidth and leadWidth != '' %} {{ leadWidth }}{% endif %}">{{ Model.Lead | raw }}</div>
    {%- endif -%}
  </div>
{%- endif -%}
