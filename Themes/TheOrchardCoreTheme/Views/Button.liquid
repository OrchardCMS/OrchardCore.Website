{%- comment -%}
  Shared call-to-action button. Invoked from block templates with:
    {{ "Button" | shape_new: url: ..., text: ..., target: ..., variant: ... | shape_render }}
  Note: shape_new PascalCases the argument names, so they are read here as Model.Url / Model.Text /
  Model.Target / Model.Variant.
  The editor picks intent only (Primary / Secondary / Ghost). The on-dark treatment is applied
  automatically by the block "theme": a button inside a `.theme-dark` section picks up the
  `theme-dark:` utility overrides below. No "on-dark" variant to choose, no branching.
{%- endcomment -%}
{%- assign url = Model.Url -%}
{%- if url and url != "" -%}
  {%- assign label = Model.Text -%}
  {%- if label == nil or label == "" -%}{%- assign label = url -%}{%- endif -%}
  {%- assign variant = Model.Variant -%}
  {%- if variant == nil or variant == "" -%}{%- assign variant = "Primary" -%}{%- endif -%}

  {%- assign base = "inline-block text-sm text-center font-semibold transition focus-visible:outline-2 focus-visible:outline-offset-2" -%}
  {%- case variant -%}
    {%- when "Secondary" -%}
      {%- assign cls = "rounded-md px-5 py-3 bg-green-100 text-green-800 hover:bg-green-200 focus-visible:outline-green-700 theme-dark:bg-white/10 theme-dark:text-white theme-dark:ring-1 theme-dark:ring-white/20 theme-dark:hover:bg-white/15 theme-dark:focus-visible:outline-white" -%}
    {%- when "Ghost" -%}
      {%- assign cls = "underline underline-offset-2 text-green-700 decoration-green-700/30 hover:decoration-green-700 focus-visible:outline-green-700 theme-dark:text-accent-bright theme-dark:decoration-accent-bright/40 theme-dark:hover:decoration-accent-bright theme-dark:focus-visible:outline-white" -%}
    {%- else -%}
      {%- assign cls = "rounded-md px-5 py-3 bg-green-600 text-white hover:bg-green-700 focus-visible:outline-green-700 theme-dark:bg-accent-bright theme-dark:text-green-900 theme-dark:hover:bg-accent-bright-hover theme-dark:focus-visible:outline-accent-bright" -%}
  {%- endcase -%}

  <a href="{{ url | href }}" class="{{ base }} {{ cls }}"{% if Model.Target and Model.Target != "" %} target="{{ Model.Target }}" rel="noopener"{% endif %}>{{ label }}</a>
{%- endif -%}
