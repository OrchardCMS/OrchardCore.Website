{%- comment -%}
  Shared profile avatar. Invoked as:
    {{ "ProfileAvatar" | shape_new: item: <profile>, class: "<img classes>", width: 240, sizes: "..." | shape_render }}
  (shape_new PascalCases the args → Model.Item / Model.Class / Model.Width / Model.Sizes.) Renders the
  person's uploaded Photo as a responsive square (via the Image shape). If no photo is set but a GitHub
  URL is, it falls back to that user's GitHub avatar (github.com/<handle>.png) at the right ?size= for
  1x/2x. Alt text is the media text if set, else the item title (the name). Width is the 1x display px.
{%- endcomment -%}
{%- assign profile = Model.Item -%}
{%- assign photo = profile.Profile.Photo.Paths.first -%}
{%- assign alt = profile.Profile.Photo.MediaTexts.first | default: profile.DisplayText -%}
{%- assign width = Model.Width | default: 200 -%}
{%- assign sizes = Model.Sizes | default: "200px" -%}
{%- if photo -%}
  {{ "Image" | shape_new: path: photo, alt: alt, width: width, height: width, sizes: sizes, class: Model.Class | shape_render }}
{%- else -%}
  {%- assign githubUrl = profile.Profile.GitHubUrl.Text -%}
  {%- if githubUrl and githubUrl != "" -%}
    {%- assign handle = githubUrl | split: '/' | last -%}
    {%- if handle and handle != "" -%}
      {%- assign base = 'https://github.com/' | append: handle | append: '.png' -%}
      {%- assign x2 = width | times: 2 -%}
      <img src="{{ base }}?size={{ width }}" srcset="{{ base }}?size={{ width }} 1x, {{ base }}?size={{ x2 }} 2x" width="{{ width }}" height="{{ width }}" alt="{{ alt }}" loading="lazy" decoding="async" class="{{ Model.Class }}">
    {%- endif -%}
  {%- endif -%}
{%- endif -%}
