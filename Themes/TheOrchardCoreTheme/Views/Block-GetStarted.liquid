{%- comment -%}
  Get Started. Heading + lead, then a two-column layout: a tabbed code box (left) of install methods
  and a stack of no-install option cards (right), closing with the shared BlockActions row.
  The code tabs are CSS-only (hidden radios + named peers, like CardTabs) — no JavaScript for switching.
  Each panel is a terminal: the snippet's colours are authored in the content via the [cmd]/[name]/
  [comment]/[flag]/[type] shortcode tags (rendered `| shortcode | raw`); theme.js only powers the
  `.copy-btn` (strips comments + prompts so the clipboard holds runnable commands). Band/anchor from Section.
{%- endcomment -%}
{%- assign intro = Model.ContentItem.Content.BlockIntro -%}
{%- assign section = Model.ContentItem.Content.BlockPart -%}
{%- assign themeName = section.Theme.Text | default: "White" | downcase -%}
{%- assign anchor = section.AnchorId.Text -%}
{%- assign methods = Model.ContentItem.Content.Methods.ContentItems -%}
{%- assign options = Model.ContentItem.Content.Options.ContentItems -%}
{%- assign blockActions = Model.ContentItem.Content.BlockActionsPart -%}
{%- assign uid = Model.ContentItem.ContentItemId -%}

<section {% if anchor and anchor != "" %}id="{{ anchor }}"{% endif %} class="theme-{{ themeName }}">
  <div class="mx-auto max-w-content px-6 band">

    {{ "BlockIntro" | shape_new: title: intro.Title.Text, lead: intro.Lead.Html | shape_render }}

    <div class="mt-10 grid gap-4 lg:grid-cols-5 lg:items-stretch">

      {%- comment -%} Left: tabbed code box. CSS-only via named peers (no JS): radios are peers, the
        matching label + panel react with peer-checked/m<i>. Flat grid so the radios are siblings of
        both. Rows are `auto / 1fr`: the tabs keep their natural height (row 1) and the checked panel
        (row 2) fills the rest, so the box matches the option-cards column height without stretching the tabs. {%- endcomment -%}
      {%- if methods.size > 0 -%}
        {%- comment -%} A CSS-only radio group (hidden radios drive peer-checked panel switching), not a
          WAI-ARIA tab widget: role="group" (no required-children constraint) keeps the accessible group
          name without the aria-required-children violation a tablist/radiogroup would raise here. {%- endcomment -%}
        <div class="grid grid-cols-[repeat(4,auto)_1fr] overflow-hidden rounded-2xl bg-code-bg shadow-soft lg:col-span-3 lg:grid-rows-[auto_1fr] theme-dark:ring-1 theme-dark:ring-white/10" role="group" aria-label="Ways to start">
          {%- for method in methods -%}
            <input class="peer/m{{ forloop.index0 }} sr-only" type="radio" name="code-{{ uid }}" id="code-{{ uid }}-{{ forloop.index0 }}"{% if forloop.first %} checked{% endif %}>
          {%- endfor -%}
          {%- for method in methods -%}
            <label class="row-start-1 cursor-pointer border-b-2 border-transparent px-5 py-3.5 text-sm font-bold text-white/55 transition hover:text-white peer-checked/m{{ forloop.index0 }}:border-accent-bright peer-checked/m{{ forloop.index0 }}:text-white focus-within:outline-2 focus-within:outline-offset-2 focus-within:outline-amber" for="code-{{ uid }}-{{ forloop.index0 }}">{{ method.DisplayText }}</label>
          {%- endfor -%}
          {%- for method in methods -%}
            <div data-code-block class="hidden relative col-[1/-1] row-start-2 border-t border-white/10 peer-checked/m{{ forloop.index0 }}:block">
              <button type="button" class="copy-btn absolute right-3 top-3 z-10 rounded-full border border-white/20 px-3 py-1 text-xs text-white/70 transition hover:bg-white/10 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber">Copy</button>
              <pre class="overflow-x-auto p-6 font-mono text-sm leading-relaxed text-code-ink"><code>{{ method.StartMethod.CodeSnippet.Text | shortcode | raw }}</code></pre>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Right: no-install option cards. Each option's Theme picks its look (Dark = featured
        green card; the `theme-dark` class also gives the shared Button shape its on-dark treatment), and
        its buttons come from the CallToActions bag, rendered through the same Button shape as every block. {%- endcomment -%}
      {%- if options.size > 0 -%}
        <div class="grid gap-4 sm:grid-cols-2 lg:col-span-2 lg:grid-cols-1 lg:grid-rows-2">
          {%- for option in options -%}
            {%- assign optionTheme = option.StartOption.Theme.Text | default: "White" -%}
            {%- assign optionActions = option.CallToActions.ContentItems -%}
            {%- if optionTheme == "Dark" -%}
              <div class="theme-dark flex h-full flex-col rounded-xl bg-green-900 p-6 text-white">
                <h3 class="text-xl text-white">{{ option.DisplayText }}</h3>
                <div class="prose mt-3 flex-1">{{ option.StartOption.Body.Html | shortcode | raw }}</div>
            {%- else -%}
              <div class="flex h-full flex-col rounded-xl bg-white p-6 theme-dark:bg-white/5">
                <h3 class="text-xl text-green-900 theme-dark:text-white">{{ option.DisplayText }}</h3>
                <div class="prose mt-3 flex-1 text-ink-soft theme-dark:text-green-100/80">{{ option.StartOption.Body.Html | shortcode | raw }}</div>
            {%- endif -%}
                {%- if optionActions.size > 0 -%}
                  <div class="mt-6 flex flex-wrap items-center gap-3">
                    {%- for callToAction in optionActions -%}
                      {{ "Button" | shape_new: url: callToAction.CallToAction.Link.Url, text: callToAction.CallToAction.Link.Text, target: callToAction.CallToAction.Link.Target, variant: callToAction.CallToAction.Variant.Text | shape_render }}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>

    {%- comment -%} Closing actions row: copy from BlockActionsPart, buttons from the CallToActions bag. {%- endcomment -%}
    {%- capture actionsHtml -%}
      {%- for callToAction in Model.ContentItem.Content.CallToActions.ContentItems -%}
        {{ "Button" | shape_new: url: callToAction.CallToAction.Link.Url, text: callToAction.CallToAction.Link.Text, target: callToAction.CallToAction.Link.Target, variant: callToAction.CallToAction.Variant.Text | shape_render }}
      {%- endfor -%}
    {%- endcapture -%}
    {{ "BlockActions" | shape_new: heading: blockActions.Heading.Text, text: blockActions.Text.Html, actions: actionsHtml, maxWidth: "max-w-none" | shape_render }}

  </div>
</section>
