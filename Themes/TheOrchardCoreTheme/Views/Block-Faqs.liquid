{%- comment -%}
  FAQs. Heading + lead, then an accordion of questions — native <details>, no JavaScript, and not
  exclusive (several can be open). Each question is the FaqItem's title (DisplayText); the answer is
  its Answer HTML. Closes with the shared BlockActions row. Band/anchor + theme come from the Block part.

  AI / search discoverability: a schema.org FAQPage JSON-LD block is emitted from the same questions
  (built-in Liquid only — no custom driver/handler). `json` encodes each string safely (System.Text.Json
  escapes <, >, & so the data can't break out of the <script>) and `strip_html` reduces answers to plain
  text; `| raw` stops the values being HTML-encoded again. One FAQPage per FAQs block.
{%- endcomment -%}
{%- assign intro = Model.ContentItem.Content.BlockIntro -%}
{%- assign section = Model.ContentItem.Content.BlockPart -%}
{%- assign themeName = section.Theme.Text | default: "White" | downcase -%}
{%- assign anchor = section.AnchorId.Text -%}
{%- assign questions = Model.ContentItem.Content.Questions.ContentItems -%}
{%- assign blockActions = Model.ContentItem.Content.BlockActionsPart -%}

<section {% if anchor and anchor != "" %}id="{{ anchor }}"{% endif %} class="theme-{{ themeName }}">
  <div class="mx-auto max-w-content px-6 band">

    {{ "BlockIntro" | shape_new: title: intro.Title.Text, lead: intro.Lead.Html, wrapperWidth: "mx-auto max-w-4xl" | shape_render }}

    {%- if questions.size > 0 -%}
      <div class="mx-auto mt-12 max-w-4xl space-y-3">
        {%- for faq in questions -%}
          <details class="group rounded-xl bg-cream-deep px-6 theme-cream:bg-white theme-dark:bg-white/5">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-6 py-5 [&::-webkit-details-marker]:hidden focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-700">
              <h3 class="text-base text-green-900 theme-dark:text-white">{{ faq.DisplayText }}</h3>
              <svg class="h-5 w-5 shrink-0 text-green-600 transition-transform duration-300 group-open:rotate-180 theme-dark:text-green-100/80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="pb-5">
              <div class="prose max-w-none">{{ faq.FaqItem.Answer.Html | shortcode | raw }}</div>
              {%- assign faqActions = faq.CallToActions.ContentItems -%}
              {%- if faqActions.size > 0 -%}
                <div class="mt-5 flex flex-wrap items-center gap-3">
                  {%- for callToAction in faqActions -%}
                    {{ "Button" | shape_new: url: callToAction.CallToAction.Link.Url, text: callToAction.CallToAction.Link.Text, target: callToAction.CallToAction.Link.Target, variant: callToAction.CallToAction.Variant.Text | shape_render }}
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          </details>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Closing actions row: copy from BlockActionsPart, buttons from the CallToActions bag. {%- endcomment -%}
    {%- capture actionsHtml -%}
      {%- for callToAction in Model.ContentItem.Content.CallToActions.ContentItems -%}
        {{ "Button" | shape_new: url: callToAction.CallToAction.Link.Url, text: callToAction.CallToAction.Link.Text, target: callToAction.CallToAction.Link.Target, variant: callToAction.CallToAction.Variant.Text | shape_render }}
      {%- endfor -%}
    {%- endcapture -%}
    {{ "BlockActions" | shape_new: heading: blockActions.Heading.Text, text: blockActions.Text.Html, actions: actionsHtml | shape_render }}

  </div>
</section>

{%- comment -%} schema.org FAQPage structured data (JSON-LD) for AI/search discoverability. Registered
   as a foot script (RegisterFootScript) via scriptblock, so it renders at the bottom of the body — in
   the Layout's `{% resources type: "FootScript" %}` — rather than inline at the block's position. {%- endcomment -%}
{%- if questions.size > 0 -%}
{% scriptblock at:"Foot", type:"application/ld+json" %}{ "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{%- for faq in questions -%}{% unless forloop.first %},{% endunless %}{ "@type": "Question", "name": {{ faq.DisplayText | json | raw }}, "acceptedAnswer": { "@type": "Answer", "text": {{ faq.FaqItem.Answer.Html | strip_html | json | raw }} } }{%- endfor -%}] }{% endscriptblock %}
{%- endif -%}
