{% assign site_name = Site.SiteName | default: "Orchard Core" %}
{% assign page_title = Model.Title | default: Model.ContentItem | display_text | default: site_name %}
{% assign page_description = Model.Description | default: Model.ContentItem.Content.MetaDescription.Text | default: "A modular, multi-tenant application framework and CMS for ASP.NET Core." %}
{% assign page_url = "https://orchardcore.net" | append: Request.Path %}
<!DOCTYPE html>
<html lang="{{ Culture.Name | default: 'en' }}">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ page_title }} · {{ site_name }}</title>
    <meta name="description" content="{{ page_description | escape }}" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="{{ page_title | escape }}" />
    <meta property="og:description" content="{{ page_description | escape }}" />
    <meta property="og:url" content="{{ page_url }}" />
    <meta property="og:site_name" content="{{ site_name | escape }}" />
    <link rel="canonical" href="{{ page_url }}" />
    <link rel="alternate" hreflang="en" href="https://orchardcore.net{{ Request.Path }}" />
    <link rel="stylesheet" href="{{ '~/Canopy/css/canopy.min.css' | href }}" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    {% resources type: "Meta" %}
    {% resources type: "HeadLink" %}
    {% resources type: "Stylesheet" %}
    {% resources type: "HeadScript" %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "SoftwareApplication",
          "name": "Orchard Core",
          "applicationCategory": "ContentManagementSystem",
          "operatingSystem": "Cross-platform",
          "url": "https://orchardcore.net",
          "creator": {
            "@type": "Organization",
            "name": "The Orchard Team"
          }
        },
        {
          "@type": "Organization",
          "name": "The Orchard Team",
          "url": "https://orchardcore.net",
          "sameAs": [
            "https://github.com/OrchardCMS/OrchardCore",
            "https://discord.gg/orchardcore"
          ]
        }
      ]
    }
    </script>
</head>
<body class="canopy-site">
{% assign trust = '' | trust_signals %}
<div class="site-shell">
    <header class="site-header site-header-zone">
        <div class="container site-header__inner">
            <a class="brand-lockup" href="{{ '~/' | href }}" aria-label="{{ 'Orchard Core home' | t }}">
                <span class="brand-lockup__mark">OC</span>
                <span>
                    <strong>{{ 'Orchard Core' | t }}</strong><br />
                    <span class="type-sm">{{ 'Composable apps and CMS' | t }}</span>
                </span>
            </a>
            <div class="site-nav">
                <div class="site-nav__links">
                    <a class="site-nav__link" href="https://docs.orchardcore.net/" data-analytics-event="docs_clicked">{{ 'Docs' | t }}</a>
                    <a class="site-nav__link" href="https://github.com/OrchardCMS/OrchardCore">{{ 'GitHub' | t }}</a>
                    <a class="site-nav__link" href="https://orchardcore.net/discord">{{ 'Community' | t }}</a>
                    <a class="site-nav__cta" href="https://try.orchardcore.net/">{{ 'Try' | t }}</a>
                </div>
                <a class="github-chip" href="https://github.com/OrchardCMS/OrchardCore" aria-label="{{ 'GitHub stars' | t }}">
                    <span>★</span>
                    <span>{{ trust.Stars | default: 0 }}</span>
                </a>
                <button class="theme-toggle" type="button" data-theme-toggle aria-pressed="false">
                    <span class="theme-toggle__icon">◐</span>
                    <span data-theme-label>{{ 'Dark mode' | t }}</span>
                </button>
                {% comment %}
                <nav class="language-switcher" aria-label="{{ 'Language switcher' | t }}">
                    <a href="{{ Request.Path }}" hreflang="en" class="{% if Culture.Name == 'en' %}is-active{% endif %}">EN</a>
                    <a href="{{ '/fr' | append: Request.Path }}" hreflang="fr" class="{% if Culture.Name contains 'fr' %}is-active{% endif %}">FR</a>
                </nav>
                {% endcomment %}
            </div>
        </div>
        {% if Model.Header != nil %}
            <div class="container">{{ Model.Header | shape_render }}</div>
        {% endif %}
    </header>

    {% if Model.Navigation != nil %}
        <nav class="site-navigation-zone">{{ Model.Navigation | shape_render }}</nav>
    {% endif %}

    {% if Model.HeroZone != nil %}
        <section class="site-hero-zone">{{ Model.HeroZone | shape_render }}</section>
    {% endif %}

    {% if Model.BeforeContent != nil %}
        <section class="site-before-content-zone shell-container section-stack">{{ Model.BeforeContent | shape_render }}</section>
    {% endif %}

    <main class="site-main-zone shell-container section-stack" id="main-content">
        {% if Model.Content != nil %}
            {{ Model.Content | shape_render }}
        {% endif %}
    </main>

    {% if Model.AfterContent != nil %}
        <section class="site-after-content-zone shell-container section-stack">{{ Model.AfterContent | shape_render }}</section>
    {% endif %}

    {% if Model.AsideFirst != nil %}
        <aside class="site-aside-first-zone section-stack" aria-label="{{ 'Primary sidebar' | t }}">{{ Model.AsideFirst | shape_render }}</aside>
    {% endif %}

    {% if Model.AsideSecond != nil %}
        <aside class="site-aside-second-zone section-stack" aria-label="{{ 'Secondary sidebar' | t }}">{{ Model.AsideSecond | shape_render }}</aside>
    {% endif %}

    <footer class="site-footer site-footer-zone">
        <div class="container site-footer__grid">
            {% if Model.Footer != nil %}
                {{ Model.Footer | shape_render }}
            {% else %}
                <div class="site-footer__brand">
                    <h2>{{ 'Build with Orchard Core' | t }}</h2>
                    <p>{{ 'A modern, modular framework and CMS for ambitious .NET teams.' | t }}</p>
                </div>
            {% endif %}
        </div>
        {% if Model.Analytics != nil %}
            <div class="container">{{ Model.Analytics | shape_render }}</div>
        {% endif %}
    </footer>
</div>
<script src="{{ '~/Canopy/js/canopy.bundle.js?v=1.8.3' | href }}" defer></script>
    {% resources type: "FootScript" %}
</body>
</html>