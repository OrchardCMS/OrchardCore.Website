{% assign widget = Model.ContentItem.Content.ComparisonTableWidget %}
{% assign rows = widget.Rows.ContentItemIds | content_item_id %}
<section class="section-stack reveal comparison-table" id="platform-comparison" data-observe-event="compare_viewed" data-analytics-label="platform-comparison">
    <div class="prose">
        <span class="eyebrow">{{ widget.Eyebrow.Text | default: 'Comparison' | t }}</span>
        <h2>{{ widget.Headline.Text | default: 'Compare Orchard Core to legacy stacks' | t }}</h2>
    </div>
    <div class="comparison-table__scroll">
        <table>
            <thead>
                <tr>
                    <th>{{ 'Capability' | t }}</th>
                    <th class="comparison-table__platform--orchardcore">Orchard Core</th>
                    <th class="comparison-table__platform--umbraco">Umbraco</th>
                    <th class="comparison-table__platform--abp">abp.io</th>
                    <th class="comparison-table__platform--sitecore">Sitecore</th>
                    <th class="comparison-table__platform--kentico">Kentico</th>
                </tr>
            </thead>
            <tbody>
                {% for row in rows %}
                    {% assign cr = row.Content.ComparisonRow %}
                    <tr>
                        <th scope="row">{{ row | display_text }}</th>
                        {% assign oc_text = cr.OrchardCoreText.Text | default: cr.OrchardCore.Value %}
                        <td><span class="comparison-mark comparison-{{ oc_text | downcase }}">{{ oc_text }}</span></td>
                        {% assign um_text = cr.UmbracoText.Text | default: cr.Umbraco.Value %}
                        <td><span class="comparison-mark comparison-{{ um_text | downcase }}">{{ um_text }}</span></td>
                        {% assign abp_text = cr.AbpText.Text | default: cr.Abp.Value %}
                        <td><span class="comparison-mark comparison-{{ abp_text | downcase }}">{{ abp_text }}</span></td>
                        {% assign sc_text = cr.SitecoreText.Text | default: cr.Sitecore.Value %}
                        <td><span class="comparison-mark comparison-{{ sc_text | downcase }}">{{ sc_text }}</span></td>
                        {% assign ke_text = cr.KenticoText.Text | default: cr.Kentico.Value %}
                        <td><span class="comparison-mark comparison-{{ ke_text | downcase }}">{{ ke_text }}</span></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
