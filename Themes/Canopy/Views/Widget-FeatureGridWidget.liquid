{% assign widget = Model.ContentItem.Content.FeatureGridWidget %}
{% assign features = widget.Features.ContentItemIds | content_item_id %}
<section class="section-stack reveal">
    <div class="prose">
        <span class="eyebrow">{{ widget.Eyebrow.Text | default: 'Capabilities' | t }}</span>
        <h2>{{ widget.Headline.Text | default: 'Compose your application experience' | t }}</h2>
        <p>{{ widget.Subheadline.Text | default: 'Feature building blocks that scale from content pages to line-of-business solutions.' | t }}</p>
    </div>
    <div class="card-grid">
        {% for feature in features %}
            {% assign detail_url = feature | display_url %}
            <article class="feature-card">
                <div class="feature-card__body">
                    {% assign feature_icon = feature.Content.Feature.Icon.Text %}
                    <div class="feature-card__icon">{% if feature_icon != blank %}<i class="fa-solid {{ feature_icon }}" aria-hidden="true"></i>{% else %}⬢{% endif %}</div>
                    <h3>{{ feature | display_text }}</h3>
                    <p>{{ feature.Content.Feature.Summary.Text | default: feature.Content.HtmlBodyPart.Body | strip_html | truncatewords: 28 }}</p>
                    <a href="{{ feature.Content.Feature.DocsLink.Url | default: detail_url | href }}" data-analytics-event="docs_clicked">{{ 'Read the docs' | t }}</a>
                </div>
            </article>
        {% endfor %}
    </div>
</section>
