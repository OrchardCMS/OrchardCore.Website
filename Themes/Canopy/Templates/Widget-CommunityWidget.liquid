<section class="section-stack reveal zone-card">
    <div class="prose">
        <span class="eyebrow">{{ 'Community' | t }}</span>
        <h2>{{ 'Meet the people behind Orchard Core' | t }}</h2>
        <p>{{ 'Join the conversation, listen to the weekly podcast, and meet the ecosystem at Harvest.' | t }}</p>
    </div>
    <div class="card-grid">
        <article class="feature-card">
            <div class="feature-card__body">
                <div class="feature-card__icon">💬</div>
                <h3>{{ 'Discord' | t }}</h3>
                <p>{{ 'Get help, share ideas, and meet contributors in real time.' | t }}</p>
                <a href="https://discord.gg/orchardcore" data-analytics-event="discord_clicked">{{ 'Join Discord' | t }}</a>
            </div>
        </article>
        <article class="feature-card">
            <div class="feature-card__body">
                <div class="feature-card__icon">🗣️</div>
                <h3>{{ 'GitHub Discussions' | t }}</h3>
                <p>{{ 'Ask product questions, share announcements, and collaborate in the open.' | t }}</p>
                <a href="https://github.com/OrchardCMS/OrchardCore/discussions">{{ 'Open discussions' | t }}</a>
            </div>
        </article>
        <article class="feature-card">
            <div class="feature-card__body">
                <div class="feature-card__icon">🎙️</div>
                <h3>{{ 'Podcast' | t }}</h3>
                <p>{{ 'Tune in to the weekly live community podcast and roadmap conversation.' | t }}</p>
                <a href="https://orchardcore.net/meeting">{{ 'Watch the podcast' | t }}</a>
            </div>
        </article>
        <article class="feature-card">
            <div class="feature-card__body">
                <div class="feature-card__icon">🌾</div>
                <h3>{{ 'Harvest' | t }}</h3>
                <p>{{ 'Plan your Orchard Core conference week with workshops, sessions, and hallway chats.' | t }}</p>
                <a href="https://harvestcms.com/">{{ 'Explore Harvest' | t }}</a>
            </div>
        </article>
    </div>
</section>
