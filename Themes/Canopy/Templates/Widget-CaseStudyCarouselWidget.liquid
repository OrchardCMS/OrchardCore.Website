{% assign widget = Model.ContentItem.Content.CaseStudyCarouselWidget %}
{% assign studies = widget.CaseStudies.ContentItems %}
<section class="section-stack reveal" id="case-studies" data-observe-event="casestudy_viewed" data-analytics-label="case-study-carousel">
    <div class="prose">
        <span class="eyebrow">{{ widget.Eyebrow.Text | default: 'Case studies' | t }}</span>
        <h2>{{ widget.Headline.Text | default: 'Teams shipping Orchard Core in production' | t }}</h2>
    </div>
    <div class="logo-wall">
        {% for study in studies %}
            <article class="case-study-card logo-wall__item" aria-label="{{ study | display_text }}">
                <div class="case-study-card__shot">
                    {% if study.CaseStudy.Screenshot.Paths.first != blank %}
                        <img src="{{ study.CaseStudy.Screenshot.Paths.first | asset_url }}" alt="{{ study | display_text | escape }}" loading="lazy" />
                    {% endif %}
                </div>
                <div class="case-study-card__body">
                    <div class="case-study-card__logo">
                        {% if study.CaseStudy.OrganizationLogo.Paths.first != blank %}
                            <img src="{{ study.CaseStudy.OrganizationLogo.Paths.first | asset_url }}" alt="{{ study | display_text | escape }}" loading="lazy" />
                        {% else %}
                            {{ study | display_text | slice: 0, 2 }}
                        {% endif %}
                    </div>
                    <span class="industry-pill">{{ study.CaseStudy.Industry.Text | default: 'Digital platform' | t }}</span>
                    <h3>{{ study | display_text }}</h3>
                    <p>{{ study.CaseStudy.Summary.Text }}</p>
                    <p><strong>{{ 'Results' | t }}:</strong> {{ study.CaseStudy.Results.Text }}</p>
                    <a href="{{ study.CaseStudy.LiveUrl.Url | default: study | display_url }}">{{ 'View case study' | t }}</a>
                </div>
            </article>
        {% endfor %}
    </div>
</section>
