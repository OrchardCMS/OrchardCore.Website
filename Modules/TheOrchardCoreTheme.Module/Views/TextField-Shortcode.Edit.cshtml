@model OrchardCore.ContentFields.ViewModels.EditTextFieldViewModel
@{
    var settings = Model.PartFieldDefinition.GetSettings<TextFieldSettings>();
}

@*
    A TextField editor that adds the shortcode picker. The ShortcodeModal shape renders the picker
    modal and loads its script/styles; the `shortcode-modal-input` class makes shortcodes.js wrap the
    input with an "insert shortcode" button. Used by setting the field Editor to "Shortcode".
*@
<div class="mb-3 ocat-wrapper" id="@Html.IdFor(x => x.Text)_FieldWrapper">
    <label asp-for="Text" class="form-label">@Model.PartFieldDefinition.DisplayName()</label>
    <div class="ocat-end">
        @await DisplayAsync(await New.ShortcodeModal())
        <input asp-for="Text" class="form-control shortcode-modal-input content-preview-text" placeholder="@settings.Placeholder" />
        <span asp-validation-for="Text"></span>
        @if (!string.IsNullOrEmpty(settings.Hint))
        {
            <span class="hint">@settings.Hint</span>
        }
    </div>
</div>
