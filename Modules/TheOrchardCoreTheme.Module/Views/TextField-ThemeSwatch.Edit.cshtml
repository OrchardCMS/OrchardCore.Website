@model OrchardCore.ContentFields.ViewModels.EditTextFieldViewModel
@{
    var listSettings = Model.PartFieldDefinition.GetSettings<TextFieldPredefinedListEditorSettings>();
    var textSettings = Model.PartFieldDefinition.GetSettings<TextFieldSettings>();
    var options = listSettings?.Options ?? Array.Empty<ListValueOption>();
    var current = string.IsNullOrEmpty(Model.Text) ? listSettings?.DefaultValue : Model.Text;
    var groupName = Html.NameFor(m => m.Text);
    var baseId = Html.IdFor(m => m.Text);

    // Preview colors per theme value (block band backgrounds + readable "Aa" color).
    var swatches = new Dictionary<string, (string bg, string fg)>(StringComparer.OrdinalIgnoreCase)
    {
        ["White"] = ("#ffffff", "#08361a"),
        ["Cream"] = ("#f5f8f6", "#08361a"),
        ["Rule"]  = ("#e2e8e3", "#08361a"),
        ["Dark"]  = ("#08361a", "#ffffff"),
    };
}

@*
    Visual theme picker for a TextField (set the field Editor to "ThemeSwatch"). Renders the field's
    PredefinedList options as swatches that preview each block band, as a radio group bound to Text.
*@
<div class="mb-3" id="@(baseId)_FieldWrapper">
    <label class="form-label">@Model.PartFieldDefinition.DisplayName()</label>
    <div class="theme-swatches">
        @foreach (var opt in options)
        {
            var optId = $"{baseId}_{opt.Value}";
            var colors = swatches.TryGetValue(opt.Value ?? string.Empty, out var c) ? c : (bg: "#e5e7eb", fg: "#374151");
            <div class="theme-swatch">
                <input class="theme-swatch__input" type="radio" id="@optId" name="@groupName" value="@opt.Value" checked="@(string.Equals(opt.Value, current, StringComparison.OrdinalIgnoreCase))" />
                <label class="theme-swatch__label" for="@optId">
                    <span class="theme-swatch__preview" style="background:@colors.bg; color:@colors.fg;">Aa</span>
                    <span class="theme-swatch__name">@opt.Name</span>
                </label>
            </div>
        }
    </div>
    <span asp-validation-for="Text"></span>
    @if (!string.IsNullOrEmpty(textSettings?.Hint))
    {
        <span class="hint">@textSettings.Hint</span>
    }
</div>

<style>
    .theme-swatches { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: .25rem; }
    .theme-swatch__input { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
    .theme-swatch__label { display: flex; flex-direction: column; align-items: center; gap: .45rem; cursor: pointer; margin: 0; }
    .theme-swatch__preview {
        display: flex; align-items: center; justify-content: center;
        width: 57px; height: 57px; border-radius: 0.375rem;
        font-weight: 700; font-size: 1.05rem; line-height: 1;
        box-shadow: inset 0 0 0 1px rgba(8, 54, 26, .15);
        transition: box-shadow .15s ease;
    }
    .theme-swatch__name { font-size: .8rem; color: #6b7280; }
    .theme-swatch__input:checked + .theme-swatch__label .theme-swatch__preview {
        box-shadow: inset 0 0 0 1px rgba(8, 54, 26, .15), 0 0 0 2px #fff, 0 0 0 4px #1c9148;
    }
    .theme-swatch__input:checked + .theme-swatch__label .theme-swatch__name { color: #111827; font-weight: 600; }
    .theme-swatch__input:focus-visible + .theme-swatch__label .theme-swatch__preview { outline: 2px solid #1c9148; outline-offset: 3px; }
</style>
