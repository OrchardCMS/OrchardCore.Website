{
  "name": "TheOrchardCoreTheme.Model.CardGridTabbed",
  "displayName": "Orchard Core Website - Content Model",
  "description": "The Cards Grid (Tabbed) block and its Tab items (each Tab holds a set of shared Cards).",
  "author": "Orchard Core",
  "version": "1.0.0",
  "issetuprecipe": false,
  "categories": [
    "theme"
  ],
  "steps": [
    {
      "name": "ReplaceContentDefinition",
      "ContentTypes": [
        {
          "Name": "CardGridTabbed",
          "DisplayName": "Cards Grid (Tabbed)",
          "Settings": {
            "ContentTypeSettings": {
              "Stereotype": "Block",
              "Category": "Content",
              "ThumbnailPath": "~/TheOrchardCoreTheme/block-thumbnails/CardGridTabbed.png?v=2",
              "Description": "Feature cards split into switchable tabs."
            }
          },
          "ContentTypePartDefinitionRecords": [
            {
              "PartName": "BlockPart",
              "Name": "BlockPart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "0"
                }
              }
            },
            {
              "PartName": "BlockIntro",
              "Name": "BlockIntro",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "1"
                }
              }
            },
            {
              "PartName": "BagPart",
              "Name": "Tabs",
              "Settings": {
                "ContentTypePartSettings": {
                  "DisplayName": "Tabs",
                  "Description": "Audience tabs; each tab is a labelled set of cards shown via the toggle.",
                  "Position": "2"
                },
                "BagPartSettings": {
                  "ContainedContentTypes": [
                    "Tab"
                  ],
                  "CollapseContainedItems": true
                }
              }
            },
            {
              "PartName": "BlockActionsPart",
              "Name": "BlockActionsPart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "3"
                }
              }
            },
            {
              "PartName": "BagPart",
              "Name": "CallToActions",
              "Settings": {
                "ContentTypePartSettings": {
                  "DisplayName": "Call To Actions",
                  "Description": "The closing call-to-action buttons shown beneath the grid.",
                  "Position": "4"
                },
                "BagPartSettings": {
                  "ContainedContentTypes": [
                    "CallToAction"
                  ],
                  "CollapseContainedItems": true
                }
              }
            },
            {
              "PartName": "TitlePart",
              "Name": "TitlePart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "0"
                },
                "TitlePartSettings": {
                  "Options": 2,
                  "Pattern": "{{ Model.ContentItem.Content.BlockIntro.Title.Text }}",
                  "RenderTitle": false
                }
              }
            }
          ]
        },
        {
          "Name": "Tab",
          "DisplayName": "Tab",
          "Settings": {
            "ContentTypeSettings": {
              "Stereotype": ""
            }
          },
          "ContentTypePartDefinitionRecords": [
            {
              "PartName": "Tab",
              "Name": "Tab",
              "Settings": {}
            },
            {
              "PartName": "BagPart",
              "Name": "Cards",
              "Settings": {
                "ContentTypePartSettings": {
                  "DisplayName": "Cards",
                  "Description": "The cards shown for this tab.",
                  "Position": "1"
                },
                "BagPartSettings": {
                  "ContainedContentTypes": [
                    "Card"
                  ],
                  "CollapseContainedItems": true
                }
              }
            },
            {
              "PartName": "TitlePart",
              "Name": "TitlePart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "0"
                },
                "TitlePartSettings": {
                  "Options": 2,
                  "Pattern": "{{ Model.ContentItem.Content.Tab.Title.Text }}",
                  "RenderTitle": false
                }
              }
            }
          ]
        }
      ],
      "ContentParts": [
        {
          "Name": "Tab",
          "Settings": {
            "ContentPartSettings": {
              "Description": "An audience/segment of cards; its title is the toggle label."
            }
          },
          "ContentPartFieldDefinitionRecords": [
            {
              "FieldName": "TextField",
              "Name": "Title",
              "Settings": {
                "ContentPartFieldSettings": {
                  "DisplayName": "Title",
                  "Position": "0"
                },
                "TextFieldSettings": {
                  "Hint": "The toggle label, e.g. For Developers"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
