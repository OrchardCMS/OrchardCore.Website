{
  "name": "TheOrchardCoreTheme.Model.Showcase",
  "displayName": "Orchard Core Website - Content Model",
  "description": "The Showcase block and its ShowcaseItem items.",
  "author": "Orchard Core",
  "version": "1.0.0",
  "issetuprecipe": false,
  "categories": [
    "theme"
  ],
  "steps": [
    {
      "name": "ReplaceContentDefinition",
      "ContentTypes": [
        {
          "Name": "Showcase",
          "DisplayName": "Showcase",
          "Settings": {
            "ContentTypeSettings": {
              "Stereotype": "Block",
              "Category": "Content",
              "ThumbnailPath": "~/TheOrchardCoreTheme/block-thumbnails/Showcase.png?v=2",
              "Description": "A gallery of sites or projects built with the product."
            }
          },
          "ContentTypePartDefinitionRecords": [
            {
              "PartName": "BlockPart",
              "Name": "BlockPart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "0"
                }
              }
            },
            {
              "PartName": "BlockIntro",
              "Name": "BlockIntro",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "1"
                }
              }
            },
            {
              "PartName": "BagPart",
              "Name": "Items",
              "Settings": {
                "ContentTypePartSettings": {
                  "DisplayName": "Items",
                  "Description": "The projects shown in the gallery.",
                  "Position": "2"
                },
                "BagPartSettings": {
                  "ContainedContentTypes": [
                    "ShowcaseItem"
                  ],
                  "CollapseContainedItems": true
                }
              }
            },
            {
              "PartName": "BlockActionsPart",
              "Name": "BlockActionsPart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "3"
                }
              }
            },
            {
              "PartName": "BagPart",
              "Name": "CallToActions",
              "Settings": {
                "ContentTypePartSettings": {
                  "DisplayName": "Call To Actions",
                  "Description": "The closing call-to-action button shown beneath the gallery.",
                  "Position": "4"
                },
                "BagPartSettings": {
                  "ContainedContentTypes": [
                    "CallToAction"
                  ],
                  "CollapseContainedItems": true
                }
              }
            },
            {
              "PartName": "TitlePart",
              "Name": "TitlePart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "0"
                },
                "TitlePartSettings": {
                  "Options": 2,
                  "Pattern": "{{ Model.ContentItem.Content.BlockIntro.Title.Text }}",
                  "RenderTitle": false
                }
              }
            }
          ]
        },
        {
          "Name": "ShowcaseItem",
          "DisplayName": "Showcase Item",
          "Settings": {
            "ContentTypeSettings": {
              "Stereotype": ""
            }
          },
          "ContentTypePartDefinitionRecords": [
            {
              "PartName": "ShowcaseItem",
              "Name": "ShowcaseItem",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "1"
                }
              }
            },
            {
              "PartName": "TitlePart",
              "Name": "TitlePart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "0"
                },
                "TitlePartSettings": {
                  "Options": 0,
                  "RenderTitle": false
                }
              }
            }
          ]
        }
      ],
      "ContentParts": [
        {
          "Name": "ShowcaseItem",
          "Settings": {
            "ContentPartSettings": {
              "Description": "A showcase project: an image and an optional link. The item's title is the project name and the image alt text."
            }
          },
          "ContentPartFieldDefinitionRecords": [
            {
              "FieldName": "MediaField",
              "Name": "Image",
              "Settings": {
                "ContentPartFieldSettings": {
                  "DisplayName": "Image",
                  "Editor": "Gallery",
                  "Position": "0"
                },
                "MediaFieldSettings": {
                  "Multiple": false,
                  "AllowMediaText": false,
                  "AllowAnchors": false,
                  "Hint": "The project screenshot or image."
                }
              }
            },
            {
              "FieldName": "TextField",
              "Name": "Url",
              "Settings": {
                "ContentPartFieldSettings": {
                  "DisplayName": "Link URL",
                  "Editor": "Url",
                  "Position": "1"
                },
                "TextFieldSettings": {
                  "Hint": "Optional. If set, the card links to this project URL. Leave blank for a non-linked card."
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
