{
  "name": "TheOrchardCoreTheme.Model.SiteHeader",
  "displayName": "Orchard Core Website - Content Model",
  "description": "Header widget model. A SocialLinks widget (GitHub / Documentation / Discord / YouTube URLs, rendered through the shared SocialLinks shape) placed via Layers in the site-wide 'Header' zone, so the header's icons are content-managed. The header's primary navigation is built separately from each LandingPage's opted-in section blocks (BlockPart.ShowInNav / NavText).",
  "author": "Orchard Core",
  "version": "1.0.0",
  "issetuprecipe": false,
  "categories": [
    "theme"
  ],
  "steps": [
    {
      "name": "ReplaceContentDefinition",
      "ContentTypes": [
        {
          "Name": "SocialLinks",
          "DisplayName": "Social Links",
          "Settings": {
            "ContentTypeSettings": {
              "Stereotype": "Widget",
              "Description": "A row of icon links (GitHub, Documentation, Discord, YouTube)."
            }
          },
          "ContentTypePartDefinitionRecords": [
            {
              "PartName": "TitlePart",
              "Name": "TitlePart",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "0"
                },
                "TitlePartSettings": {
                  "Options": 0,
                  "RenderTitle": false
                }
              }
            },
            {
              "PartName": "SocialLinks",
              "Name": "SocialLinks",
              "Settings": {
                "ContentTypePartSettings": {
                  "Position": "1"
                }
              }
            }
          ]
        }
      ],
      "ContentParts": [
        {
          "Name": "SocialLinks",
          "Settings": {
            "ContentPartSettings": {
              "Description": "Social profile URLs; each one that is set renders an icon link."
            }
          },
          "ContentPartFieldDefinitionRecords": [
            {
              "FieldName": "TextField",
              "Name": "GitHubUrl",
              "Settings": {
                "ContentPartFieldSettings": {
                  "DisplayName": "GitHub URL",
                  "Editor": "Url",
                  "Position": "0"
                },
                "TextFieldSettings": {
                  "Hint": "Optional. Shows a GitHub icon link when set."
                }
              }
            },
            {
              "FieldName": "TextField",
              "Name": "DocsUrl",
              "Settings": {
                "ContentPartFieldSettings": {
                  "DisplayName": "Documentation URL",
                  "Editor": "Url",
                  "Position": "1"
                },
                "TextFieldSettings": {
                  "Hint": "Optional. Shows a documentation icon link, next to GitHub, when set."
                }
              }
            },
            {
              "FieldName": "TextField",
              "Name": "DiscordUrl",
              "Settings": {
                "ContentPartFieldSettings": {
                  "DisplayName": "Discord URL",
                  "Editor": "Url",
                  "Position": "2"
                },
                "TextFieldSettings": {
                  "Hint": "Optional. Shows a Discord icon link when set."
                }
              }
            },
            {
              "FieldName": "TextField",
              "Name": "YouTubeUrl",
              "Settings": {
                "ContentPartFieldSettings": {
                  "DisplayName": "YouTube URL",
                  "Editor": "Url",
                  "Position": "3"
                },
                "TextFieldSettings": {
                  "Hint": "Optional. Shows a YouTube icon link when set."
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
